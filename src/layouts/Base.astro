---
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  /** 首页启用导航 scrollspy */
  scrollspy?: boolean;
}

const {
  title,
  description = 'UX Engineer · Design with Code, Think with AI。徐炜楠的个人作品集与博客。',
  scrollspy = false,
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- 老文章图床（新浪图床等）有防盗链，统一不发 referrer -->
    <meta name="referrer" content="no-referrer" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <script is:inline>
      // 主题初始化必须内联在 head,避免闪烁
      (() => {
        const saved = localStorage.getItem('theme');
        const theme =
          saved === 'light' || saved === 'dark'
            ? saved
            : matchMedia('(prefers-color-scheme: dark)').matches
              ? 'dark'
              : 'light';
        document.documentElement.dataset.theme = theme;
        // 滚动显现动效仅在 JS 可用时隐藏初始状态（no-JS 兜底）
        document.documentElement.classList.add('js');
        // ?qa 直接跳过入场动画（视觉回归/自动化测试用）
        if (new URLSearchParams(location.search).has('qa')) {
          document.documentElement.dataset.qa = '';
        }
      })();
    </script>
  </head>
  <body>
    <div class="scroll-sentinel" aria-hidden="true"></div>
    <a class="skip-link" href="#main">跳到主要内容</a>
    <Header scrollspy={scrollspy} />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <script src="../scripts/global.js"></script>
  </body>
</html>
