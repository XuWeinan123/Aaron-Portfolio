---
import Base from '../layouts/Base.astro';
import MediaSlot from '../components/MediaSlot.astro';

/**
 * 活体样式指南：本站全部 Design Token 与全局组件的实渲染展示。
 * Token 定义唯一来源：src/styles/global.css(:root / [data-theme='dark'])。
 * 本页色块均通过 var() 引用，右上角切换主题即可查看两套色板。
 */

interface Token {
  v: string; // CSS 变量名
  light: string;
  dark: string;
  note?: string;
}
interface TokenGroup {
  name: string;
  en: string;
  tokens: Token[];
}

const colorGroups: TokenGroup[] = [
  {
    name: '基础面',
    en: 'Surfaces',
    tokens: [
      { v: '--bg', light: '0.972 0.004 264', dark: '0.185 0.014 264', note: '页面背景' },
      { v: '--surface', light: '1 0 0', dark: '0.205 0.012 264', note: '卡片/页脚' },
      { v: '--surface-2', light: '0.975 0.003 264', dark: '0.235 0.012 264', note: '次级填充' },
      { v: '--surface-accent', light: '0.975 0.016 262', dark: '0.26 0.045 262', note: '强调底' },
    ],
  },
  {
    name: '描边',
    en: 'Borders',
    tokens: [
      { v: '--border', light: '0.90 0.005 264', dark: '0.30 0.012 264', note: '默认' },
      { v: '--border-subtle', light: '0.93 0.004 264', dark: '0.26 0.012 264', note: '弱分隔' },
      { v: '--border-strong', light: '0.86 0.006 264', dark: '0.37 0.012 264', note: '强描边' },
    ],
  },
  {
    name: '文字',
    en: 'Text',
    tokens: [
      { v: '--text', light: '0.24 0.012 264', dark: '0.95 0.003 264', note: '主文字' },
      { v: '--text-2', light: '0.46 0.012 264', dark: '0.72 0.012 264', note: '正文/次级' },
      { v: '--text-3', light: '0.58 0.012 264', dark: '0.57 0.012 264', note: '辅助' },
      { v: '--text-mono', light: '0.55 0.01 264', dark: '0.58 0.012 264', note: 'mono 标签' },
    ],
  },
  {
    name: '强调',
    en: 'Accent',
    tokens: [
      { v: '--accent', light: '0.58 0.18 262', dark: '0.70 0.15 262', note: '主强调' },
      { v: '--accent-strong', light: '0.52 0.14 262', dark: '0.78 0.12 262', note: '强调文字' },
      { v: '--accent-deep', light: '0.34 0.06 262', dark: '0.84 0.08 262', note: '深强调' },
      { v: '--accent-border', light: '0.80 0.08 262', dark: '0.48 0.13 262', note: '强调描边' },
    ],
  },
  {
    name: '语义',
    en: 'Semantic',
    tokens: [
      { v: '--danger', light: '0.55 0.16 28', dark: '0.64 0.14 28', note: '否定/反例' },
      { v: '--success', light: '0.62 0.16 145', dark: '0.68 0.14 145', note: 'LIVE/成功' },
    ],
  },
  {
    name: '按钮',
    en: 'Button',
    tokens: [
      { v: '--btn-bg', light: '0.205 0.012 264', dark: '0.95 0.003 264', note: '主按钮底' },
      { v: '--btn-text', light: '0.97 0.003 264', dark: '0.20 0.012 264', note: '主按钮字' },
    ],
  },
  {
    name: '深色带区',
    en: 'Band',
    tokens: [
      { v: '--band-bg', light: '0.205 0.012 264', dark: '0.155 0.012 264', note: '带区底' },
      { v: '--band-surface', light: '0.235 0.012 264', dark: '0.195 0.012 264', note: '带内卡片' },
      { v: '--band-border', light: '0.32 0.012 264', dark: '0.30 0.012 264', note: '带内描边' },
      { v: '--band-accent', light: '0.70 0.15 262', dark: '同左', note: '带内强调' },
    ],
  },
];

const typeSpecimens = [
  {
    name: 'Display',
    spec: 'clamp(38px, 6.6vw, 64px) · 700 · -0.02em · lh 1.12',
    cls: 'display',
    sample: 'Welcome.',
  },
  {
    name: 'H-Section',
    spec: 'clamp(28px, 4.4vw, 44px) · 700 · -0.01em · lh 1.24',
    cls: 'h-section',
    sample: '你好，我是徐炜楠',
  },
  {
    name: 'H3',
    spec: '20–23px · 700 · -0.02em',
    cls: 'spec-h3',
    sample: '设计工程化',
  },
  {
    name: 'Lead',
    spec: 'clamp(16.5px, 2vw, 19px) · lh 1.7 · text-2',
    cls: 'lead',
    sample: '把体验问题转化成可落地的工程方案。',
  },
  {
    name: 'Body',
    spec: '16px · lh 1.74 · text',
    cls: 'spec-body',
    sample: '曾在 OPPO、小鹏深度参与多个创新型项目的设计预研。',
  },
  {
    name: 'Mono Label',
    spec: '11px · 0.18em · uppercase · JetBrains Mono',
    cls: 'mono-label',
    sample: 'Design Engineering',
  },
  {
    name: 'Mono SM',
    spec: '12px · 0.05em · JetBrains Mono',
    cls: 'mono-sm spec-monosm',
    sample: '2024.1 - 2025.3 · CASE 01',
  },
];

const radii = [
  { name: 'badge', value: '3px' },
  { name: 'card / --radius', value: '4px' },
  { name: 'button', value: '5px' },
  { name: '--radius-lg', value: '6px' },
  { name: 'chip / pill', value: '100px' },
];

const patterns = [
  { name: '经历时间线', where: '首页 · 经历', href: '/#experience' },
  { name: '行式文章列表', where: '博客列表 / 首页博客区', href: '/blog/' },
  { name: '阅前须知行', where: '首页 · 实验性项目', href: '/#projects' },
  { name: 'Playbook 聊天重建', where: 'Followup.AI · 06', href: '/work/followup-ai/#playbook' },
  { name: '行为循环 Action Cycle', where: 'Followup.AI · 05', href: '/work/followup-ai/#action-cycle' },
  { name: '三层约束 · 圆点量表', where: 'AI 设计系统 · 05', href: '/work/ai-design-system/#s05' },
  { name: '工具对比表', where: 'AI 设计系统 · 06', href: '/work/ai-design-system/#s06' },
  { name: '版本时间轴', where: 'AI 设计系统 · 09', href: '/work/ai-design-system/#s09' },
  { name: '过拟合/欠拟合线框', where: 'AI 设计系统 · 08', href: '/work/ai-design-system/#s08' },
];
---

<Base
  title="设计系统 - 徐炜楠 Aaron Xu"
  description="本站的活体样式指南：全部 Design Token（双主题 oklch 色板、字体、间距、动效）与全局组件的实渲染展示。"
>
  <div class="ds-page container">
    <!-- ============ 页头 ============ -->
    <header class="ds-head">
      <div class="mono-label reveal">Living Styleguide</div>
      <h1 class="display reveal" style="--d:.05s">
        设计<span class="accent-text">系统</span>.
      </h1>
      <p class="lead reveal" style="--d:.1s">
        本站全部 Design Token 与组件的实渲染展示。色块直接引用 CSS
        变量，右上角切换主题即可对照两套色板；唯一定义源是
        <code>src/styles/global.css</code>。
      </p>
    </header>

    <!-- ============ 01 色彩 ============ -->
    <section class="ds-section" aria-labelledby="t-color">
      <div class="section-head reveal">
        <span class="num">01</span>
        <span class="zh" id="t-color">色彩</span>
        <span class="en">Color Tokens</span>
        <span class="side mono-sm hint">oklch · L C H</span>
      </div>
      {
        colorGroups.map((group, gi) => (
          <div class="token-group reveal" style={`--d:${gi * 0.05}s`}>
            <div class="group-title">
              <span class="g-zh">{group.name}</span>
              <span class="mono-label">{group.en}</span>
            </div>
            <div class="swatches">
              {group.tokens.map((t) => (
                <div class="swatch">
                  <span
                    class:list={['sw-color', { 'sw-band': t.v.startsWith('--band') }]}
                    style={`background: var(${t.v});`}
                  />
                  <div class="sw-meta">
                    <span class="sw-name mono-sm">{t.v}</span>
                    <span class="sw-vals mono-sm">
                      <b>L</b> {t.light}
                    </span>
                    <span class="sw-vals mono-sm">
                      <b>D</b> {t.dark}
                    </span>
                    {t.note && <span class="sw-note">{t.note}</span>}
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </section>

    <!-- ============ 02 字体 ============ -->
    <section class="ds-section" aria-labelledby="t-type">
      <div class="section-head reveal">
        <span class="num">02</span>
        <span class="zh" id="t-type">字体</span>
        <span class="en">Typography</span>
      </div>
      <div class="type-stacks reveal">
        <div class="stack">
          <span class="mono-label">Sans</span>
          <span>Inter Variable → PingFang SC → Source Han Sans SC</span>
        </div>
        <div class="stack">
          <span class="mono-label">Mono</span>
          <span>JetBrains Mono Variable → SF Mono → ui-monospace</span>
        </div>
      </div>
      <div class="specimens">
        {
          typeSpecimens.map((s, i) => (
            <div class="specimen reveal" style={`--d:${i * 0.04}s`}>
              <div class="spec-meta">
                <span class="mono-sm spec-name">{s.name}</span>
                <span class="mono-sm spec-spec">{s.spec}</span>
              </div>
              <div class={s.cls}>{s.sample}</div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- ============ 03 间距与圆角 ============ -->
    <section class="ds-section" aria-labelledby="t-space">
      <div class="section-head reveal">
        <span class="num">03</span>
        <span class="zh" id="t-space">间距与圆角</span>
        <span class="en">Spacing & Radius</span>
      </div>
      <div class="space-grid">
        <div class="reveal">
          <div class="group-title">
            <span class="g-zh">圆角</span>
            <span class="mono-label">Radius Scale</span>
          </div>
          <div class="radius-row">
            {
              radii.map((r) => (
                <div class="radius-demo">
                  <span class="r-box" style={`border-radius: ${r.value};`} />
                  <span class="mono-sm">{r.value}</span>
                  <span class="r-name">{r.name}</span>
                </div>
              ))
            }
          </div>
        </div>
        <div class="reveal" style="--d:.08s">
          <div class="group-title">
            <span class="g-zh">容器与节奏</span>
            <span class="mono-label">Container & Rhythm</span>
          </div>
          <ul class="rhythm-list">
            <li><span class="mono-sm">--w-page</span> 1120px · 页面容器</li>
            <li><span class="mono-sm">--w-prose</span> 780px · 文章正文</li>
            <li><span class="mono-sm">首页区块</span> clamp(72px, 10.5vw, 136px)</li>
            <li><span class="mono-sm">案例区块</span> clamp(44px, 6.5vw, 78px)</li>
            <li><span class="mono-sm">--gutter</span> clamp(24px, 5vw, 64px)</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ============ 04 动效 ============ -->
    <section class="ds-section" aria-labelledby="t-motion">
      <div class="section-head reveal">
        <span class="num">04</span>
        <span class="zh" id="t-motion">动效</span>
        <span class="en">Motion</span>
        <span class="side mono-sm hint">prefers-reduced-motion 全部降级</span>
      </div>
      <div class="motion-grid">
        <ul class="rhythm-list reveal">
          <li><span class="mono-sm">--ease-out</span> cubic-bezier(0.22, 1, 0.36, 1)</li>
          <li><span class="mono-sm">按压反馈</span> 0.15s · scale(0.96–0.98)</li>
          <li><span class="mono-sm">颜色/描边</span> 0.2s ease</li>
          <li><span class="mono-sm">悬停位移</span> 0.25–0.35s · translateY(-2~-4px)</li>
          <li><span class="mono-sm">入场 reveal</span> 0.65s · 16px 上移 · animation</li>
          <li><span class="mono-sm">阅读进度</span> CSS scroll-driven（零 JS 监听）</li>
        </ul>
        <div class="motion-demo reveal" style="--d:.08s">
          <div class="demo-stage">
            <div class="card demo-card reveal in" id="motion-sample">
              <span class="mono-accent">01</span>
              <div>
                <div class="demo-title">入场 · 悬停 · 按压</div>
                <p>悬停看位移与投影，按下看压感，点右下按钮重播入场。</p>
              </div>
            </div>
          </div>
          <button class="btn btn-ghost replay" id="replay-motion" type="button">
            重播入场动画 <span aria-hidden="true">↺</span>
          </button>
        </div>
      </div>
    </section>

    <!-- ============ 05 组件 ============ -->
    <section class="ds-section" aria-labelledby="t-comp">
      <div class="section-head reveal">
        <span class="num">05</span>
        <span class="zh" id="t-comp">全局组件</span>
        <span class="en">Primitives</span>
      </div>

      <div class="comp-grid">
        <div class="comp reveal">
          <div class="comp-head">
            <span class="comp-name">按钮</span>
            <span class="mono-sm comp-cls">.btn / .btn-ghost</span>
          </div>
          <div class="comp-stage">
            <a class="btn" href="#t-comp">主按钮 <span class="arrow" aria-hidden="true">→</span></a>
            <a class="btn btn-ghost" href="#t-comp">次级按钮 <span aria-hidden="true">↗</span></a>
          </div>
          <p class="comp-note">悬停上浮 + 色调投影；按压 scale(0.98);箭头随悬停位移。</p>
        </div>

        <div class="comp reveal" style="--d:.05s">
          <div class="comp-head">
            <span class="comp-name">徽章与标签</span>
            <span class="mono-sm comp-cls">.badge / .chip</span>
          </div>
          <div class="comp-stage">
            <span class="badge badge-solid">EXPERIMENTAL</span>
            <span class="badge">WORK IN PROGRESS</span>
            <span class="chip">设计系统</span>
            <span class="chip">AI Agent</span>
          </div>
          <p class="comp-note">badge 用于状态与分类（3px 角）;chip 用于关键词（全圆角）。</p>
        </div>

        <div class="comp reveal">
          <div class="comp-head">
            <span class="comp-name">卡片</span>
            <span class="mono-sm comp-cls">.card</span>
          </div>
          <div class="comp-stage">
            <a class="card sample-card" href="#t-comp">
              <span class="mono-label">Card · Hover Me</span>
              <span class="sample-card-title">仅在层级需要时使用卡片</span>
              <p>否则用细线与留白分组（见能力区）。</p>
            </a>
          </div>
          <p class="comp-note">1px 描边 + 4px 角；悬停 -4px 上浮 + 色调投影。</p>
        </div>

        <div class="comp reveal" style="--d:.05s">
          <div class="comp-head">
            <span class="comp-name">区块头</span>
            <span class="mono-sm comp-cls">.section-head</span>
          </div>
          <div class="comp-stage stage-block">
            <div class="section-head sample-head">
              <span class="num">0X</span>
              <span class="zh">区块名</span>
              <span class="en">Section Label</span>
              <span class="side mono-sm">右侧插槽</span>
            </div>
          </div>
          <p class="comp-note">编号 + 中文名 + 英文 mono 标签，ds 分幕签名，全站统一。</p>
        </div>

        <div class="comp reveal">
          <div class="comp-head">
            <span class="comp-name">媒体占位</span>
            <span class="mono-sm comp-cls">MediaSlot.astro</span>
          </div>
          <div class="comp-stage stage-block">
            <MediaSlot label="示例占位" node="000:0000" ratio="21 / 9" />
          </div>
          <p class="comp-note">斜纹底 + 节点标注；替换真实图片时换成 &lt;img&gt; 即可。</p>
        </div>

        <div class="comp reveal" style="--d:.05s">
          <div class="comp-head">
            <span class="comp-name">深色带区</span>
            <span class="mono-sm comp-cls">.band / --band-*</span>
          </div>
          <div class="comp-stage stage-block">
            <div class="band sample-band">
              <span class="mono-label">Band · 明暗节奏</span>
              <div class="sample-band-inner">
                <span class="mono-sm on-accent">05</span>
                <p>带区内使用独立的 band token 族，两种主题下都保持深色。</p>
              </div>
            </div>
          </div>
          <p class="comp-note">用于案例页的关键幕（目标/Loop/转场）,源自 ds 原型深色帧。</p>
        </div>

        <div class="comp reveal">
          <div class="comp-head">
            <span class="comp-name">复制按钮</span>
            <span class="mono-sm comp-cls">[data-copy]</span>
          </div>
          <div class="comp-stage">
            <button type="button" class="sample-copy" data-copy="woshixwn@gmail.com" aria-live="polite">
              <span data-copy-label>woshixwn@gmail.com</span>
              <span class="copy-hint mono-sm">复制</span>
            </button>
          </div>
          <p class="comp-note">点击写入剪贴板，标签短暂变为「已复制」，aria-live 播报。</p>
        </div>

        <div class="comp reveal" style="--d:.05s">
          <div class="comp-head">
            <span class="comp-name">正文排版</span>
            <span class="mono-sm comp-cls">.prose</span>
          </div>
          <div class="comp-stage stage-block">
            <div class="prose sample-prose">
              <h3>三级标题</h3>
              <p>
                正文 16px / 1.9,内联 <code>code 样式</code> 与
                <a href="#t-comp">链接下划线</a>。
              </p>
              <blockquote><p>引用块：左侧强调线 + 次级填充底。</p></blockquote>
              <ul>
                <li>列表圆点使用 text-3</li>
                <li>图片自带描边与圆角，失效图降级为斜纹占位</li>
              </ul>
            </div>
          </div>
          <p class="comp-note">承载 105 篇博客正文（含 2015 年起的原始 HTML 存量文章）。</p>
        </div>
      </div>
    </section>

    <!-- ============ 06 组合模式 ============ -->
    <section class="ds-section" aria-labelledby="t-pattern">
      <div class="section-head reveal">
        <span class="num">06</span>
        <span class="zh" id="t-pattern">组合模式</span>
        <span class="en">Patterns</span>
      </div>
      <p class="lead pattern-lead reveal">
        由上述原语组合而成、跟随内容存在于具体页面的模式。点击直达实例：
      </p>
      <ul class="pattern-list">
        {
          patterns.map((p, i) => (
            <li class="reveal" style={`--d:${i * 0.04}s`}>
              <a href={p.href}>
                <span class="p-name">{p.name}</span>
                <span class="mono-sm p-where">{p.where}</span>
                <span class="p-arr" aria-hidden="true">→</span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</Base>

<script>
  // 重播入场动画示例
  const replay = document.getElementById('replay-motion');
  const sample = document.getElementById('motion-sample');
  if (replay && sample) {
    replay.addEventListener('click', () => {
      sample.classList.remove('in');
      void sample.offsetWidth; // 强制 reflow 以重启动画
      sample.classList.add('in');
    });
  }
</script>

<style>
  .ds-page {
    padding-top: clamp(112px, 15vw, 168px);
  }

  .ds-head {
    margin-bottom: clamp(40px, 6vw, 64px);
  }

  .ds-head .mono-label {
    display: block;
    margin-bottom: 22px;
  }

  .ds-head h1 {
    margin-bottom: 22px;
  }

  .ds-head .lead {
    max-width: 58ch;
  }

  .ds-head code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--surface-2);
    border: 1px solid var(--border-subtle);
    border-radius: 3px;
    padding: 0.1em 0.4em;
  }

  .ds-section {
    padding: clamp(40px, 6vw, 72px) 0 0;
  }

  .hint {
    color: var(--text-3);
    letter-spacing: 0.04em;
  }

  /* ---- 色彩 ---- */
  .token-group {
    margin-bottom: 36px;
  }

  .group-title {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 16px;
  }

  .g-zh {
    font-size: 16px;
    font-weight: 600;
  }

  .swatches {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(215px, 100%), 1fr));
    gap: 12px;
  }

  .swatch {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    padding: 14px;
  }

  .sw-color {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    border-radius: var(--radius);
    border: 1px solid var(--border);
