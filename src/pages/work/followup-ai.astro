---
import CaseLayout from '../../layouts/CaseLayout.astro';
import SectionHead from '../../components/SectionHead.astro';
import MediaSlot from '../../components/MediaSlot.astro';

const scope = [
  {
    en: 'Foundation Builder',
    title: '基础逻辑构建',
    sub: '参考竞品，搭建以表格界面为核心的数据底座。',
    body: '在初期梳理整个产品的业务逻辑，拆解 Monday 与 ClickUp 等竞品的底层架构。以表格界面为切入点，我完成了 20+ 种 Columns 的数据结构与各种样式状态的设计。并通过对流程与标准的沉淀，让后续 Column 类型的新增和维护更加便捷。',
  },
  {
    en: 'Implementation',
    title: '工程化交付',
    sub: '打通设计与开发，实现高质量交付。',
    body: '基于对核心页面的设计沉淀，以及对竞品组件库的解构，我搭建了平台所使用的 Design Library。同时通过 Figma 的 Component 与 Variables 功能，实现了设计与开发元素的 1:1 映射，并在 AI 的帮助下，实现了设计稿到代码的高质量 & 高效还原交付。',
  },
  {
    en: 'Core AI Feature',
    title: 'AI Automation',
    sub: '基于 Agent 的自动化工作流设计。',
    body: '引入 1.5b 小模型驱动智能类型识别，确保 AI 节点能精准融入传统工作流。通过自然语言对话的方式降低使用门槛，实现「描述即生成」的自动化体验，让 AI 真正转化为可感知的生产力工具。',
  },
  {
    en: 'Go Excelsior',
    title: '更进一步的探索',
    sub: '回归行为模型，填补执行的心理鸿沟。',
    body: '反思传统 IFTTT 模式对用户思维的束缚，并基于 Don Norman 的行为循环理论进行深入思考。提出 Playbook 意图沙盒构想，尝试使用 AI 将模糊意图转化为明确方案，探索「意图驱动」的 AI 交互范式。',
  },
];

const columnTypes = [
  'Text', 'Date', 'Status', 'Priority', 'People', 'Time Tracking', 'Phone', 'Hours',
  'Email', 'Timeline', 'Currency', 'Number', 'Single Select', 'Multiple Select',
  'Link', 'Files', 'Checkbox', 'Percentage', 'Toggle', 'Vote', 'Auto number',
  'Connect', 'Date created', 'Created by',
];

const statusExample = [
  {
    title: '数据类型定义',
    body: '明确使用 Enum 作为底层数据类型。通过这种抽象方式，Link、Phone、Email 以及未来可能新增的 Column，均可与 Status 共享核心交互逻辑。',
  },
  {
    title: '多种状态机设计',
    body: 'Status / Priority / Single Select / Multiple Select 等都可以共享底层抽象。',
  },
  {
    title: '不同模块变体',
    body: '针对不同模块（如 Form Builder、Automation 等）定制适配的交互变体。让 Columns 的数据能够灵活适配不同操作场景，最后都映射回核心数据库 —— 表格。',
  },
];

const actionCycle = [
  '产生目标',
  '明确意图',
  '确定方案',
  '执行方案',
  '外部世界',
  '感知结果',
  '理解并评估',
  '对比目标结果',
];

const playbookIdeas = [
  '使用 Timeline 编排大致的 Step。',
  '无需担心模糊输入，AI 会在和你聊天时细化。',
  'AI 分析信息，提炼动作。',
  'Actions 包含项目管理中常用的动作，甚至还可以执行 Automation。',
  '通过对聊天范式的设计，AI 可以帮助用户明晰目标，智能推荐 Action。',
];
---

<CaseLayout
  title="Followup.AI - 案例 · 徐炜楠"
  description="基于 AI Agent 工作流的团队协作与项目管理平台。从 0 到 1 的设计系统搭建与 AI 交互范式探索。"
  index="CASE 01"
  category="AI 产品设计 · B 端 SaaS"
  heading="Followup.AI"
  summary="这是一家位于美国加州的 AI 创业公司开发的基于 AI Agent 工作流的团队协作与项目管理平台。产品旨在简化复杂的项目管理工具，让不同部门的用户以轻松的方式高效管理公司事务。"
  meta={[
    { label: 'Role', value: '设计系统 / 组件库搭建 · 全功能设计与落地' },
    { label: 'Type', value: 'B 端产品 / AI Base 工具 / 从 0 设计' },
    { label: 'Timeframe', value: '2024.1 - 2025.3' },
  ]}
  slug="followup-ai"
>
  <!-- 概览图 -->
  <div class="container case-section">
    <div class="reveal">
      <MediaSlot label="Followup.AI 产品概览截图" ratio="16 / 9" src="/media/followup/overview.jpg" />
    </div>
  </div>

  <!-- 01 四大板块 -->
  <section id="scope" class="container case-section">
    <SectionHead num="01" zh="项目范围" en="Four-Part Scope" />
    <div class="scope-grid">
      {
        scope.map((s, i) => (
          <div class="card scope-card reveal" style={`--d:${i * 0.07}s`}>
            <div class="scope-head">
              <span class="mono-accent">{String(i + 1).padStart(2, '0')}</span>
              <span class="mono-label">{s.en}</span>
            </div>
            <h3>{s.title}</h3>
            <div class="scope-sub">{s.sub}</div>
            <p>{s.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- 02 Foundation Builder -->
  <section id="foundation" class="container case-section">
    <SectionHead num="02" zh="基础逻辑构建" en="Foundation Builder" />
    <div class="duo">
      <div class="reveal">
        <h3 class="duo-title">拆解竞品，极速落地</h3>
        <p class="duo-body">
          通过深度解构 Monday 和 ClickUp 等成熟产品的底层逻辑，快速完成了 20+ 种 Column
          类型的定义与设计。这套基础的数据底座，不仅支撑了产品初期的极速迭代，更确保了系统骨架的稳健性。
        </p>
      </div>
      <div class="reveal" style="--d:.1s">
        <h3 class="duo-title">沉淀规则，减少重复劳动</h3>
        <p class="duo-body">
          在新增了一部分 Columns
          后，我对设计链路进行了总结，建立了一套标准化的扩充与维护流程。这使得后续在调整
          Columns 类型时变得愈发快捷、可控，显著提升了长期的工程交付效率。
        </p>
      </div>
    </div>

    <div class="column-wall reveal">
      <div class="mono-label wall-title">20+ Column Types</div>
      <div class="wall">
        {columnTypes.map((c, i) => <span class="chip" style={`--d:${i * 0.02}s`}>{c}</span>)}
      </div>
    </div>

    <div class="status-example reveal">
      <div class="mono-label ex-title">
        Status Column · 抽象示例
      </div>
      <div class="ex-grid">
        {
          statusExample.map((e, i) => (
            <div class="card ex-card reveal" style={`--d:${i * 0.07}s`}>
              <h4>{e.title}</h4>
              <p>{e.body}</p>
            </div>
          ))
        }
      </div>
    </div>

    <div class="reveal" style="margin-top: 34px;">
      <MediaSlot label="Foundation Builder 全景截图" node="539:8772" ratio="16 / 9" />
    </div>
  </section>

  <!-- 03 Design Library -->
  <section id="library" class="container case-section">
    <SectionHead num="03" zh="工程化交付" en="Design Library & Delivery" />
    <p class="section-lead lead reveal">
      在构建 Design Library
      时，我充分运用开发知识，与前端团队紧密合作，最终打造出一套与开发组件高度一致的设计系统。这不仅显著提高了开发效率，也确保了设计的高保真落地。
    </p>

    <div class="steps reveal">
      <div class="step">
        <span class="mono-accent">一</span>
        <p>梳理组件属性，确保涵盖多数情况。</p>
      </div>
      <span class="step-arr" aria-hidden="true">→</span>
      <div class="step">
        <span class="mono-accent">二</span>
        <p>使用 Variables 实现 Color Token。</p>
      </div>
      <span class="step-arr" aria-hidden="true">→</span>
      <div class="step">
        <span class="mono-accent">三</span>
        <p>在开发 IDE 中同步实现。</p>
      </div>
    </div>

    <div class="media-pair">
      <div class="reveal">
        <MediaSlot label="Design Library 组件视觉" node="539:8904" ratio="4 / 3" />
      </div>
      <div class="reveal" style="--d:.08s">
        <MediaSlot label="Variables / Color Token 视觉" node="539:8919" ratio="4 / 3" />
      </div>
    </div>

    <div class="outcome-grid">
      <div class="card outcome reveal">
        <span class="mono-label">Outcome 01</span>
        <p>🎁 开发者借助 Figma Dev + AI，轻松还原设计。</p>
      </div>
      <div class="card outcome reveal" style="--d:.08s">
        <span class="mono-label">Outcome 02</span>
        <p>🎁 灵活使用 Color Token，快速实现主题色切换。</p>
      </div>
    </div>

    <blockquote class="aside reveal">
      额外的，我也将这套方法论应用到了我自己的产品中，在我更熟悉的 iOS
      应用项目中，开发 + 设计实现了进一步的融合。
    </blockquote>
  </section>

  <!-- 04 AI Automation -->
  <section id="automation" class="container case-section">
    <SectionHead num="04" zh="核心 AI 功能" en="AI Automation">
      <span slot="side" class="mono-sm scenario-tag">🤖 例子：HR 招聘流程</span>
    </SectionHead>
    <p class="section-lead lead reveal">
      这是我们平台的核心功能，用户可以借助这个 Feature，将一些高度重复的内容自动化，大大提升工作效率。而借助
      LLM 的 AI 能力，更是大大降低了这个工具的使用门槛。
    </p>
    <div class="scenario reveal">
      <span class="mono-label">Scenario</span>
      <p>AI 会归类候选人，并将信息后发给对应的部门。</p>
    </div>

    <div class="reveal" style="margin-bottom: 46px;">
      <MediaSlot label="Automation 工作流视觉" node="539:9040" ratio="21 / 9" />
    </div>

    <div class="auto-block reveal">
      <h3>明确节点输入输出，实现涌现式交互</h3>
      <p class="duo-body">
        涌现设计就如同积木一样，由简单基本单元组合复杂整体。我为每个节点都规划了输入、输出、执行动作，依靠这三个简单的属性，用户可以在规则内将节点们自由组合，实现需要的自动化场景。
      </p>
      <div class="node-model" aria-label="节点模型：输入 → 执行动作 → 输出">
        <span class="node-box">输入</span>
        <span class="node-arr" aria-hidden="true">→</span>
        <span class="node-box node-core">执行动作 / 配置</span>
        <span class="node-arr" aria-hidden="true">→</span>
        <span class="node-box">输出</span>
      </div>
    </div>

    <div class="auto-block reveal">
      <h3>在 AI 节点上应用小模型，快速配置输出</h3>
      <p class="duo-body">
        对于输出格式并不确定的 AI 节点，我使用了 1.5b
        小模型来根据上下文智能判断节点的输入输出。用户无需手动配置节点的输出，就可以流畅干脆的编写出想要的
        Automation。
      </p>
      <figure class="prompt-box">
        <figcaption class="mono-label">AI Extract Prompt · 来自设计稿</figcaption>
        <pre>Extract candidate's data from mail, use candidate's name as item name,
and extract other data: Age, Degree, Phone, Applied Position,
Email Address, Email Subject, Email Summary, Attachment.
Also, set the Status to Pending Review always.</pre>
      </figure>
    </div>

    <div class="auto-block reveal">
      <h3>使用内嵌式 AI 对话，进一步降低门槛</h3>
      <p class="duo-body">
        回头再整体地看 Automation，依然觉得有些复杂。用户依然需要一定的编程思维，来理解节点之间的关系。我此时从
        notion 获得了灵感，尝试将 AI 对话直接嵌入到 Automation
        中。使用自然语言描述简单诉求，AI 会尝试理解并组合节点。
      </p>
      <blockquote class="aside">
        目前效果还不怎么理想。不过我相信随着 LLM 的发展，以及节点种类的不断完善，应该会越来越好。
      </blockquote>
    </div>
  </section>

  <!-- 05 Action Cycle（深色带） -->
  <section id="action-cycle" class="container case-section">
    <div class="band cycle-band reveal">
      <div class="band-head">
        <span class="mono-accent num">05</span>
        <span class="band-zh">反思</span>
        <span class="mono-label">So, What's Next?</span>
      </div>
      <h2 class="h-section">回归行为模型，重新思考</h2>
      <p class="band-lead">
        虽然说基础的自动化功能已实现，并引入了 AI 来降低使用门槛，但依然没有脱离传统的
        IFTTT 框架（If this then that）。这个功能看上去依然还是一个编程工具，需要使用者有一定的程序化思维，使用门槛依然不低。
      </p>
      <p class="band-lead strong">
        因此我回归到最基础的行为模型（Action Cycle），重新思考：应该如何「基于
        AI」设计，而不是「结合 AI」设计。
      </p>

      <div class="cycle" role="img" aria-label="Don Norman 行为循环：产生目标 → 明确意图 → 确定方案 → 执行方案 → 外部世界 → 感知结果 → 理解并评估 → 对比目标结果">
        {
          actionCycle.map((step, i) => (
            <>
              <span class:list={['cycle-step', { hi: i === 1 || i === 2 }]}>{step}</span>
              {i < actionCycle.length - 1 && <span class="cycle-arr" aria-hidden="true">→</span>}
            </>
          ))
        }
        <span class="cycle-arr loop" aria-hidden="true">↺</span>
      </div>
      <div class="cycle-src mono-sm">Source · Donald Norman ——《设计心理学》</div>

      <div class="insight-grid">
        <div class="insight">
          <span class="mono-accent">✕</span>
          <p>
            之前那版的 Automation，即使加上 AI 能力，最多从「执行方案」开始帮忙。
          </p>
        </div>
        <div class="insight">
          <span class="mono-accent">✓</span>
          <p>
            但很多普通用户实际上卡在「要怎么做」这里，因此我希望设计的 AI
            工具能够从「明确意图 / 确定方案」开始提供帮助。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 06 Playbook -->
  <section id="playbook" class="container case-section">
    <SectionHead num="06" zh="新功能构想" en="New Feature: Playbook" />
    <p class="section-lead lead reveal">
      🥸 <strong>Playbook</strong> —— 高效率的任务生成器，让用户与 AI
      共同构建逻辑的任务流。
    </p>

    <div class="playbook-grid">
      <ul class="idea-list reveal">
        {
          playbookIdeas.map((idea) => (
            <li>
              <span class="idea-dot" aria-hidden="true" />
              {idea}
            </li>
          ))
        }
      </ul>

      <!-- 按内容重建的 Playbook 聊天界面（原 Figma 复杂节点） -->
      <div class="chat-mock card reveal" style="--d:.1s" aria-label="Playbook 聊天界面重建示意">
        <div class="mock-side">
          <div class="mock-logo mono-sm">Followup.AI</div>
          <ul>
            <li>Notifications</li>
            <li>My action items</li>
            <li class="active">Playbooks</li>
            <li>Integrations</li>
            <li>Forms</li>
          </ul>
        </div>
        <div class="mock-chat">
          <div class="msg ai reveal" style="--d:.25s">
            <span class="who mono-sm">AI</span>
            <p>
              About the mail. Do you need I summary the candidate's mail? I can create an
              automation for that.
            </p>
          </div>
          <div class="msg user reveal" style="--d:.45s">
            <p>Yes, good idea</p>
          </div>
          <div class="msg ai reveal" style="--d:.65s">
            <span class="who mono-sm">AI</span>
            <p>I also suggest add a Status column to keep track.</p>
          </div>
          <div class="msg user reveal" style="--d:.85s">
            <p>Yes, use 'Pending' as default</p>
          </div>
          <div class="mock-input mono-sm" aria-hidden="true">和 AI 协作任何事…</div>
        </div>
      </div>
    </div>

    <div class="reveal" style="margin-top: 40px;">
      <MediaSlot label="Playbook UI 视觉" ratio="21 / 9" src="/media/followup/playbook.jpg" />
    </div>
  </section>

  <!-- 「下一个案例」卡由 CaseLayout 按 cases.ts 顺序自动生成 -->
</CaseLayout>

<style>
  /* ---- Scope ---- */
  .scope-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(300px, 100%), 1fr));
    gap: 16px;
  }

  .scope-card {
    padding: 32px 32px 34px;
  }

  .scope-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 20px;
  }

  .scope-card h3 {
    font-size: 22px;
    margin-bottom: 8px;
  }

  .scope-sub {
    font-size: 14px;
    font-weight: 500;
    color: var(--accent-strong);
    margin-bottom: 14px;
  }

  .scope-card p {
    font-size: 14.5px;
    color: var(--text-2);
  }

  /* ---- 双栏文案 ---- */
  .duo {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(300px, 100%), 1fr));
    gap: clamp(24px, 4vw, 48px);
    margin-bottom: 42px;
  }

  .duo-title {
    font-size: 21px;
    margin-bottom: 12px;
  }

  .duo-body {
    color: var(--text-2);
    font-size: 15px;
  }

  /* ---- Column wall ---- */
  .column-wall {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    padding: 26px 28px 28px;
    margin-bottom: 34px;
  }

  .wall-title {
    margin-bottom: 18px;
  }

  .wall {
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
  }

  .wall .chip {
    font-family: var(--font-mono);
    font-size: 12px;
    transition: border-color 0.2s ease, color 0.2s ease, transform 0.25s var(--ease-out);
  }

  .wall .chip:hover {
    border-color: var(--accent-border);
    color: var(--accent-strong);
  }

  @media (hover: hover) and (pointer: fine) {
    .wall .chip:hover {
      transform: translateY(-2px);
    }
  }

  .ex-title {
    margin-bottom: 16px;
  }

  .ex-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(260px, 100%), 1fr));
    gap: 14px;
  }

  .ex-card {
    padding: 24px 24px 26px;
  }

  .ex-card h4 {
    font-size: 16.5px;
    margin-bottom: 10px;
  }

  .ex-card p {
    font-size: 13.5px;
    color: var(--text-2);
  }

  /* ---- Steps ---- */
  .steps {
    display: flex;
    align-items: stretch;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 34px;
  }

  .step {
    flex: 1;
    min-width: 200px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    padding: 20px 22px;
    display: flex;
    gap: 14px;
    align-items: baseline;
  }

  .step .mono-accent {
    font-size: 13px;
  }

  .step p {
    font-size: 14.5px;
    color: var(--text-2);
  }

  .step-arr {
    align-self: center;
    color: var(--text-3);
    font-size: 20px;
  }

  @media (max-width: 700px) {
    .step-arr {
      display: none;
    }
  }

  .media-pair {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(280px, 100%), 1fr));
    gap: 16px;
    margin-bottom: 30px;
  }

  .outcome-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(280px, 100%), 1fr));
    gap: 14px;
  }

  .outcome {
    padding: 22px 26px;
    background: var(--surface-accent);
    border-color: var(--accent-border);
  }

  .outcome .mono-label {
    color: var(--accent-strong);
    display: block;
    margin-bottom: 10px;
  }

  .outcome p {
    font-size: 15px;
    font-weight: 500;
  }

  .aside {
    margin: 34px 0 0;
    padding: 18px 24px;
    border-left: 2px solid var(--accent);
    background: var(--surface-2);
    border-radius: 0 var(--radius) var(--radius) 0;
    color: var(--text-2);
    font-size: 15px;
  }

  /* ---- Automation ---- */
  .scenario-tag {
    color: var(--text-2);
    letter-spacing: 0.02em;
  }

  .scenario {
    display: flex;
