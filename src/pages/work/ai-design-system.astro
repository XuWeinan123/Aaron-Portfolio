---
import Base from '../../layouts/Base.astro';
import MediaSlot from '../../components/MediaSlot.astro';

/**
 * 长案例：复合设计系统 —— 按 ds/project 原型的 15 个分幕重建。
 * 视觉与原型逐幕对照：编号区块头 + 明暗节奏（05/09/转场为深色带）。
 */

const whyCards = [
  {
    en: 'Capability',
    title: 'AI 能力跨过门槛',
    body: '我有独立开发的经历，所以会经常接触 AI Coding 类工具，因此关注到 LLM 模型的指令遵循和逻辑推演越来越强。其中 Opus 4.6 是感受最为强烈的版本。',
  },
  {
    en: 'Protocol',
    title: 'DESIGN.md 指明方向',
    body: 'Google 的 DESIGN.md 协议虽粗浅，却点明：设计系统不再只是设计内部的事，可以直接下探到 code。开源的 Open Design 框架也给了我不少参考灵感。',
  },
  {
    en: 'Personal',
    title: '顺便补自己的短板',
    body: '交互出身的我视觉能力一直都是偏弱的。所以也想看看能不能借 AI「大力出奇迹」，换一种方式把自己的视觉设计能力也拉上来。',
  },
];

const framework = [
  {
    label: '01 · 目标',
    title: '我要去哪',
    body: '先讲清楚理想的产出长什么样，把方向定下来 —— 没有方向，后面的每一步都无从判断。',
    ref: '见 05 · 三层约束',
  },
  {
    label: '02 · 度量',
    title: '怎么知道接近了',
    body: '找一把不夹带私货的尺子，客观验证设计系统本身的效果，而不是工具的审美。',
    ref: '见 06 · 选工具',
  },
  {
    label: '03 · 迭代',
    title: '不对时改哪里',
    body: '把问题放回系统，一轮轮收敛 —— 这是「如何思考」的元方法，也是全篇分量最重的部分。',
    ref: '见 07–09 · Origin / 调参 / Loop',
  },
];

/** 三层约束（自上而下渲染：PATTERN → LANGUAGE → TOKEN） */
const layers = [
  {
    key: 'PATTERN',
    name: '场景范式',
    body: '设计语言在具体场景里的稳定做法：导航怎么组织、页面如何布局、各种局部控件怎么用。',
    quant: 3,
    risk: 3,
    accent: false,
  },
  {
    key: 'LANGUAGE',
    name: '设计判断',
    body: '产品气质与设计语言。最空泛，也是我最担心 AI 的一层 —— 它和人一样会误读抽象概念。年少时我也常把「无边界」「水生设计」这种语言理解偏，还得靠评审矫正。',
    quant: 1,
    risk: 5,
    accent: false,
  },
  {
    key: 'TOKEN',
    name: '视觉原子',
    body: '颜色 / 字号 / 间距 / 圆角 / 阴影。最定量，也是 AI 最不会出错的一层。',
    quant: 5,
    risk: 1,
    accent: true,
  },
];

const tools = [
  {
    name: 'Stitch',
    verdict: '噪音太大',
    why: '会带上 Google 的设计语言 —— 适合发散探索，不适合做度量。',
    chosen: false,
  },
  {
    name: 'Claude Design',
    verdict: '太聪明',
    why: '内置专业工作流会预先矫正结果，测不准系统本身，而且很烧 token。',
    chosen: false,
  },
  {
    name: 'Claude Code',
    verdict: '老实但有用',
    why: '严苛遵循给定系统，还能追问「为什么这样设计」、指出设计依据 —— 看得见判断的过程。',
    chosen: true,
  },
];

const metricChecks = ['设计语言是否跑偏', '高频组件是否误用', '是否生成无意义文案与装饰'];

const loopSteps = [
  'CC 按最新的 DESIGN.md + 固定结构，生成页面',
  '按度量维度查看、记录问题',
  '反问 CC 要设计依据，连同问题入「问题池」',
  '选几个互不关联的问题，用 Codex + Git 改 DESIGN.md',
  '回到 01，再来一轮',
];

const tuningPrinciples = [
  ['准备', '风格各异的测试样本', '，暴露过拟合'],
  ['每轮', '只修一个维度', '，便于归因'],
  ['规则系统', '抽象、拆够细', ''],
  ['善用 ', 'Anti 描述', '，阻断高频套路'],
  ['结构化，降低', '上下文稀释', ''],
];

const examples = [
  {
    ver: 'v0.6 → 0.7',
    title: '过拟合：每页都像首页',
    rows: [
      ['现象', '生成的其他页面都带浓浓首页风格，都想放个大 Hero。'],
      ['定位', '提供的 Components 太少，AI 只能退回通用组件。'],
      ['处理', '0.6.x 起逐步增补，0.7 补充大量 Components。'],
    ],
    verify: '过拟合现象明显改善。',
  },
  {
    ver: 'v0.8',
    title: '规则遵守：List 总不留间隔',
    rows: [
      ['现象', 'List 规则要求 item 间留间隔，AI 不稳定遵守。'],
      ['定位', 'AI 按 HTML 标签判断「是不是 List」，而非视觉。'],
      ['处理', '改 Dm —— 要求按视觉特征判断，而非代码标签。'],
    ],
    verify: 'Workflow 面板里确有 subagent 做视觉检测，且产物合规。',
  },
];

const results = [
  { idx: 'A', zh: '仪表盘', en: 'Dashboard', body: '高信息密度，多组件并置。' },
  { idx: 'B', zh: '数据表', en: 'Data Table', body: '以表格为主，强调对齐与可读性。' },
  { idx: 'C', zh: '表单 / 详情', en: 'Form & Detail', body: '留白充足，引导式的纵向布局。' },
];

const issues = [
  {
    idx: 'ISSUE 01',
    tag: '待下游补强',
    title: '中文适应，尤其是寡行',
    body: 'AI 似乎难以理解「单行只剩 1–2 个字」这种西文里罕见的寡行问题。虽然可以要求它加上 text-wrap: pretty 从 CSS 层面兜底，但我更想建立一套通用、跨平台的约束。',
    plan: '在下游增加一个「寡行检测」Step，交给单独的 AI（可能试试国内模型）专门处理。',
  },
  {
    idx: 'ISSUE 02',
    tag: '待上游补强',
    title: 'Design Pattern 需要拆分',
    body: '0.9 之后想给每个页面的各部分都补上范式（如 Landing Page 各部分的用法），但这又把问题带回了最初的过拟合。若像 Components 那样堆更多范式能减轻它，却很容易让 DESIGN.md 变得超长、占满 AI 的上下文窗口。',
    plan: '在上游用某种 Skill，动态生成当前页面所需的那部分 Design Pattern，与 DESIGN.md 一同构成设计上下文。',
  },
];

const closingInsights = [
  '过去的设计系统解决人与人的协作；AI 时代的设计系统，还要解决人与模型如何协作。',
  '设计师要把原本只存在于经验里的判断拆出来：哪些变成 token、哪些写进 language；哪些需要沉淀、哪些不能写死。',
  'AI 时代逼着我们把隐性经验，整理成 AI 能理解、执行、被验证的规则。',
];

const Dots = (n: number, danger = false) =>
  Array.from({ length: 5 }, (_, i) => ({ on: i < n, danger }));
---

<Base
  title="让 AI 稳定产出 production-level 设计稿 - 徐炜楠"
  description="一次关于「复合设计系统」的探索 —— 把设计系统从一份交付物，做成一个 AI 能执行、能验证的可运行约束系统。"
>
  <div class="progress" aria-hidden="true"><span></span></div>

  <article class="ds-case container">
    <a class="back mono-sm" href="/#projects"><span class="arr">←</span> 返回精选案例</a>

    <!-- ============ 01 封面 ============ -->
    <section id="s01" class="frame cover">
      <div class="cover-top">
        <span class="mono-sm kicker">Composite Design System</span>
        <span class="mono-sm pager">01 / 14</span>
      </div>
      <h1 class="reveal">
        让 AI 稳定产出 <span class="accent-text">production-level</span> 设计稿
      </h1>
      <p class="cover-sub lead reveal" style="--d:.08s">
        一次关于「复合设计系统」的探索 —— 把设计系统从一份交付物，做成一个 AI
        能执行、能验证的<strong>可运行约束系统</strong>。
      </p>
      <div class="takeaway reveal" style="--d:.16s">
        <div class="mono-label">Core Takeaway</div>
        <p>
          让 AI
          画一张好看的页面已不稀奇；真正难的，是当需求、页面类型、信息密度都在变时，它还能不能<span
            class="accent-text">稳定沿用同一套设计判断</span
          > —— 而不是退回互联网上最常见的模板。
        </p>
      </div>
      <div class="viewpoint reveal" style="--d:.22s">
        <span class="mono-label">Viewpoint</span>
        <span class="vsep" aria-hidden="true"></span>
        <span>交互设计 / UX 工程 · 独立探索</span>
      </div>
      <div class="credit mono-sm">本演示稿由 Claude Design 生成 · 网页版按原稿重建</div>
    </section>

    <!-- ============ 02 起点 ============ -->
    <section id="s02" class="frame">
      <div class="frame-head reveal">
        <span class="fnum mono-sm">02</span>
        <span class="fzh">起点</span>
        <span class="fen mono-label">Why Do This</span>
      </div>
      <h2 class="reveal">为什么动手做这件事</h2>
      <p class="frame-lead reveal">三件事在同一时间凑齐，把「用 AI 构建设计系统」从空想推到了眼前。</p>
      <div class="tri-grid">
        {
          whyCards.map((c, i) => (
            <div class="card pad reveal" style={`--d:${i * 0.08}s`}>
              <div class="card-kicker">
                <span class="mono-accent">{String(i + 1).padStart(2, '0')}</span>
                <span class="mono-label">{c.en}</span>
              </div>
              <h3>{c.title}</h3>
              <p>{c.body}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- ============ 03 问题 ============ -->
    <section id="s03" class="frame">
      <div class="frame-head reveal">
        <span class="fnum mono-sm">03</span>
        <span class="fzh">开工前思考</span>
        <span class="fen mono-label">Thoughts</span>
      </div>
      <div class="problem-grid">
        <div class="reveal">
          <h2>真正的难题，<br />不是「好不好看」</h2>
          <p class="frame-lead">
            当页面类型、信息密度、需求都在变，AI 很容易退回互联网上最常见的做法 ——
            俗称 <span class="mono-accent">「AI 味」</span>。难点是：如何让它在不同页面里，<strong
              >稳定沿用同一套设计判断？</strong
            >
          </p>
          <div class="project-zero">
            <div class="pz-head">
              <span class="pz-dot" aria-hidden="true"></span>
              <span class="mono-sm">PROJECT · TOTAL ZERO</span>
            </div>
            <p>
              恰好手上有一个公司内部全新项目，刻意与旧视觉资产拆开，不必迁就旧体系 ——
              适合从零验证一套 AI 设计工作流。
            </p>
          </div>
        </div>

        <!-- 反例：刻意堆满「AI 味」套路 -->
        <div class="reveal" style="--d:.12s">
          <div class="ai-mock" role="img" aria-label="反例示意：堆满 AI 味套路的落地页">
            <div class="ai-mock-badge mono-sm">This is AI 味</div>
            <div class="chrome">
              <span class="cdot" style="background:#ff5f57"></span>
              <span class="cdot" style="background:#febc2e"></span>
              <span class="cdot" style="background:#28c840"></span>
              <span class="curl mono-sm">ai-startup-landing.app</span>
            </div>
            <div class="ai-hero">
              <div class="ai-pill">🚀 Now with AI</div>
              <div class="ai-title">Supercharge Your<br />Workflow with AI ✨</div>
              <div class="ai-sub">
                The all-in-one platform to build faster, ship smarter, and scale
                effortlessly. Lorem ipsum dolor sit amet.
              </div>
              <div class="ai-ctas">
                <span class="ai-btn-w">Get Started Free →</span>
                <span class="ai-btn-o">Book a Demo</span>
              </div>
            </div>
            <div class="ai-tiles">
              <div class="ai-tile" style="border-left-color:#6366f1">
                <div class="emoji">⚡</div>
                <div class="metric">10×</div>
                <div class="desc">Faster delivery</div>
              </div>
              <div class="ai-tile" style="border-left-color:#7c3aed">
                <div class="emoji">🎯</div>
                <div class="metric">99.9%</div>
                <div class="desc">Uptime SLA</div>
              </div>
              <div class="ai-tile" style="border-left-color:#4f46e5">
                <div class="emoji">🔥</div>
                <div class="metric">3×</div>
                <div class="desc">More productive</div>
              </div>
            </div>
          </div>
          <div class="anti-caption">
            <span class="x mono-sm" aria-hidden="true">✕</span>
            <p class="mono-sm">
              紫蓝渐变 Hero · emoji 功能图标 · 圆角左边框卡片 · 虚构指标 · 填充文案
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ 04 方法框架 ============ -->
    <section id="s04" class="frame">
      <div class="frame-head reveal">
        <span class="fnum mono-sm">04</span>
        <span class="fzh">方法框架</span>
        <span class="fen mono-label">Framework</span>
      </div>
      <h2 class="reveal">把模糊问题，收敛成可推进的版本</h2>
      <p class="frame-lead reveal">
        面对一件还很模糊的事，我习惯先解决三个问题。这三段，也是贯穿全篇的进度骨架。
      </p>
      <div class="fw-grid">
        {
          framework.map((f, i) => (
            <>
              <div class="card pad fw-card reveal" style={`--d:${i * 0.08}s`}>
                <div class="mono-accent fw-label">{f.label}</div>
                <div class="fw-title">{f.title}</div>
                <p>{f.body}</p>
                <div class="fw-ref mono-sm">{f.ref}</div>
              </div>
              {i < framework.length - 1 && <span class="fw-arr" aria-hidden="true">→</span>}
            </>
          ))
        }
      </div>
    </section>

    <!-- ============ 05 目标（深色） ============ -->
    <section id="s05" class="frame band-frame">
      <div class="frame-head band-head-line reveal">
        <span class="fnum mono-sm on-band-accent">05</span>
        <span class="fzh on-band">目标</span>
        <span class="fen mono-label">Goal</span>
        <span class="phase mono-sm"><b>目标</b> / 度量 / 迭代</span>
      </div>
      <div class="goal-grid">
        <div class="reveal">
          <h2 class="on-band">把 AI 当成一个需要被约束的初级设计师</h2>
          <p class="frame-lead on-band-2">
            要稳住产出下限，得同时讲清三件事：能用哪些视觉原子、整体设计语言是什么、不同场景应该怎么做。
          </p>
        </div>
        <div class="layers">
          {
            layers.map((l, i) => (
              <div class:list={['layer reveal', { 'layer-accent': l.accent }]} style={`--d:${i * 0.08}s`}>
                <div class="layer-main">
                  <div class="layer-head">
                    <span class="mono-sm lk">{l.key}</span>
                    <span class="ln">{l.name}</span>
                  </div>
                  <p>{l.body}</p>
                </div>
                <div class="meters">
                  <div class="meter">
                    <div class="mono-sm meter-label">定量程度</div>
                    <div class="dots">
                      {Dots(l.quant).map((d) => (
                        <span class:list={['pt', { on: d.on }]} />
                      ))}
                    </div>
                  </div>
                  <div class="meter">
                    <div class="mono-sm meter-label">AI 风险</div>
                    <div class="dots">
                      {Dots(l.risk, true).map((d) => (
                        <span class:list={['pt danger', { on: d.on }]} />
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            ))
          }
          <div class="layers-note mono-sm reveal">
            <span class="on-band-accent">↑ 自下而上</span>
            <span>越往上，越依赖判断、AI 风险越高</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ 06 度量 ============ -->
    <section id="s06" class="frame">
      <div class="frame-head reveal">
        <span class="fnum mono-sm">06</span>
        <span class="fzh">度量</span>
        <span class="fen mono-label">Metric</span>
        <span class="phase mono-sm">目标 / <b>度量</b> / 迭代</span>
      </div>
      <h2 class="reveal">先找一把好尺子</h2>
      <p class="frame-lead reveal">
        要验证设计系统本身的效果，工具就不能自带审美、或藏着隐性的修正工作流。
      </p>

      <div class="tool-table reveal" role="table" aria-label="候选工具对比">
        <div class="tt-row tt-head" role="row">
          <span role="columnheader" class="mono-label">候选工具</span>
          <span role="columnheader" class="mono-label">结论</span>
          <span role="columnheader" class="mono-label">为什么</span>
        </div>
        {
          tools.map((t) => (
            <div class:list={['tt-row', { chosen: t.chosen }]} role="row">
              <span role="cell" class="tt-name mono-sm">
                {t.name}
                {t.chosen && <span class="tt-check mono-sm">✓ 选用</span>}
              </span>
              <span role="cell" class:list={['tt-verdict', { good: t.chosen }]}>
                {t.verdict}
              </span>
              <span role="cell" class="tt-why">{t.why}</span>
            </div>
          ))
        }
      </div>

      <div class="checks reveal">
        <div class="checks-head">
          <span class="mono-label">重点看什么</span>
          <span class="checks-note">Token 层 AI 几乎不犯，忽略；只盯这三处。</span>
        </div>
        <div class="checks-grid">
          {
            metricChecks.map((c) => (
              <div class="check">
                <span class="mono-accent" aria-hidden="true">✓</span>
                <span>{c}</span>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ============ 07 Origin ============ -->
    <section id="s07" class="frame">
      <div class="frame-head reveal">
        <span class="fnum mono-sm">07</span>
        <span class="fzh">迭代 · Origin</span>
        <span class="fen mono-label">First Draft</span>
        <span class="phase mono-sm">目标 / 度量 / <b>迭代</b></span>
      </div>
      <div class="origin-intro reveal">
        <h2>做个垃圾出来</h2>
        <p class="frame-lead">
          不必一开始就把设计系统写完整。先抓住「改了最能影响整体观感」的两块 ——
          它们定了，Design System 的基调就定了。
        </p>
      </div>

      <div class="mono-label group-label reveal">两个高杠杆模块</div>
      <div class="lever-grid">
        <div class="lever reveal">
          <div class="lever-name">Button</div>
          <div class="lever-sub">集中了大量 token</div>
          <p>颜色、圆角、间距、状态都压在一个组件里，牵一发而动全身。</p>
        </div>
        <div class="lever reveal" style="--d:.08s">
          <div class="lever-name">Language Overview</div>
          <div class="lever-sub">设计语言总纲</div>
          <p>一句话定调，统领所有页面的气质走向。</p>
        </div>
      </div>

      <div class="mono-label group-label reveal">得到 Origin 的流程</div>
      <div class="origin-flow">
        <div class="of-step card pad-sm reveal">
          <div class="of-head">
            <span class="of-name">发散</span>
            <span class="mono-sm of-tool">STITCH</span>
          </div>
          <p>铺开多个方向，先看可能性。</p>
        </div>
        <span class="fw-arr" aria-hidden="true">→</span>
        <div class="of-step wide card pad-sm reveal" style="--d:.08s">
          <div class="of-head">
            <span class="of-name">收敛</span>
            <span class="mono-sm of-tool">CLAUDE DESIGN</span>
          </div>
          <div class="of-pills">
            <span class="chip"><span class="mono-accent">Tweaks</span>&nbsp;试方案</span>
