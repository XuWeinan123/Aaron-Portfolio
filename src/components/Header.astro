---
import Icon from './Icon.astro';

interface Props {
  scrollspy?: boolean;
}
const { scrollspy = false } = Astro.props;

/** 首页 dropdown 内的锚点项（scrollspy 高亮靠 data-nav） */
const homeMenu = [
  { href: '/#about', id: 'about', label: '关于' },
  { href: '/#experience', id: 'experience', label: '经历' },
  { href: '/#projects', id: 'projects', label: '案例' },
];

const nav = [
  { href: '/blog/', id: 'blog', label: '博客' },
  { href: '/skills/', id: 'skills', label: 'Skill' },
  { href: '/products/', id: 'products', label: '产品' },
  { href: '/design/', id: 'design', label: '组件' },
];

const path = Astro.url.pathname;
/** 独立页面的导航高亮 */
const activeId = path.startsWith('/blog')
  ? 'blog'
  : path.startsWith('/skills')
    ? 'skills'
    : path.startsWith('/products') || path.startsWith('/tools')
      ? 'products'
      : path.startsWith('/design')
        ? 'design'
        : null;
const isHome = path === '/';
const currentLabel = activeId
  ? nav.find((item) => item.id === activeId)?.label
  : isHome
    ? '首页'
    : '导航';
---

<header class="site-header" data-scrollspy={scrollspy ? 'true' : undefined}>
  <div class="inner container">
    <a class="brand" href="/" aria-label="返回首页">
      <span class="zh">徐炜楠</span>
      <span class="divider" aria-hidden="true">/</span>
      <span class="en mono-sm">AARON XU</span>
    </a>
    <nav class="desktop-nav" aria-label="主导航">
      <div class="nav-drop">
        <a class="trigger" href="/#about" aria-haspopup="true">
          首页
          <Icon name="caret-down" size={11} class="caret" />
        </a>
        <div class="menu">
          {
            homeMenu.map((item) => (
              <a href={item.href} data-nav={item.id}>
                {item.label}
              </a>
            ))
          }
        </div>
      </div>
      {
        nav.map((item) => (
          <a
            href={item.href}
            data-nav={item.id}
            class:list={{ active: item.id === activeId }}
          >
            {item.label}
          </a>
        ))
      }
      <a class="contact-link" href="/#contact" data-nav="contact">
        联系我
        <Icon name="arrow-down" size={12} class="down" />
      </a>
    </nav>
    <span class="mobile-current" data-mobile-current>{currentLabel}</span>
    <button
      id="theme-toggle"
      type="button"
      aria-label="切换深浅色主题"
      title="切换深浅色主题"
    >
      <span class="icon-sun"><Icon name="sun" size={16} /></span>
      <span class="icon-moon"><Icon name="moon" size={16} /></span>
    </button>
    <button
      id="mobile-nav-toggle"
      type="button"
      aria-label="打开导航菜单"
      aria-controls="mobile-nav"
      aria-expanded="false"
    >
      <span class="icon-menu"><Icon name="list" size={20} /></span>
      <span class="icon-close"><Icon name="x" size={20} /></span>
    </button>
  </div>
  <div id="mobile-nav" class="mobile-nav-layer" aria-hidden="true">
    <nav class="mobile-nav-menu" aria-label="移动端主导航">
      <div class="mobile-nav-primary">
        <a href="/" class:list={{ active: isHome }} data-mobile-label="首页">
          <span>首页</span><span class="mono-sm">HOME</span>
        </a>
        {
          nav.map((item) => (
            <a
              href={item.href}
              data-nav={item.id}
              data-mobile-label={item.label}
              class:list={{ active: item.id === activeId }}
            >
              <span>{item.label}</span><span class="mono-sm">{item.id.toUpperCase()}</span>
            </a>
          ))
        }
        <a href="/#contact" data-nav="contact" data-mobile-label="联系我">
          <span>联系我</span><span class="mono-sm">CONTACT</span>
        </a>
      </div>
      <div class="mobile-home-group">
        <div class="mobile-group-label mono-sm">首页章节</div>
        <div class="mobile-home-links">
          {
            homeMenu.map((item) => (
              <a href={item.href} data-nav={item.id} data-mobile-label={item.label}>
                {item.label}
              </a>
            ))
          }
        </div>
      </div>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto;
    z-index: 50;
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s ease, background-color 0.3s ease;
    user-select: none;
    -webkit-user-select: none;
  }

  .site-header.scrolled {
    background: var(--header-bg);
    -webkit-backdrop-filter: blur(14px);
    backdrop-filter: blur(14px);
    border-bottom-color: var(--border);
  }

  .inner {
    display: flex;
    align-items: center;
    gap: clamp(14px, 3vw, 32px);
    height: 60px;
  }

  .brand {
    display: flex;
    align-items: baseline;
    gap: 9px;
    font-weight: 600;
    font-size: 15px;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }

  .brand .divider {
    color: var(--text-mono);
    font-family: var(--font-mono);
    font-size: 12px;
  }

  .brand .en {
    color: var(--text-mono);
    letter-spacing: 0.14em;
  }

  .desktop-nav {
    display: flex;
    align-items: center;
    gap: clamp(4px, 1.6vw, 10px);
    margin-left: auto;
  }

  .desktop-nav a {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 14px;
    color: var(--text-2);
    padding: 7px 10px;
    border-radius: var(--radius);
    transition: color 0.2s ease, background-color 0.2s ease;
    white-space: nowrap;
  }

  .desktop-nav a:active {
    color: var(--text);
    background: color-mix(in oklch, var(--text) 9%, transparent);
  }

  .desktop-nav a.active {
    color: var(--accent-strong);
    font-weight: 500;
  }

  /* ---- 首页 dropdown ---- */
  .nav-drop {
    position: relative;
  }

  .nav-drop .trigger :global(.caret) {
    color: var(--text-3);
    transition: transform 0.2s var(--ease-out);
  }

  .nav-drop .menu {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    min-width: 128px;
    display: flex;
    flex-direction: column;
    padding: 6px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    /* 出现动效：从触发器一侧（上缘）缩放淡入；不从 scale(0) 起步 */
    transform-origin: top left;
    opacity: 0;
    transform: scale(0.96) translateY(-4px);
    pointer-events: none;
    transition: opacity 0.18s var(--ease-out), transform 0.18s var(--ease-out);
  }

  /* hover 前后菜单之间的 6px 空隙用伪元素补上，避免移动途中菜单收起 */
  .nav-drop .menu::before {
    content: '';
    position: absolute;
    inset: -8px 0 auto;
    height: 8px;
  }

  .nav-drop:focus-within .menu {
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }

  .nav-drop:focus-within .trigger :global(.caret) {
    transform: rotate(180deg);
  }

  .nav-drop .menu a {
    padding: 8px 12px;
    font-size: 13.5px;
  }

  /* 当前滚动区块在菜单内高亮时，触发器同步点亮 */
  .nav-drop:has(.menu a.active) .trigger {
    color: var(--accent-strong);
    font-weight: 500;
  }

  /* 联系我：向下箭头提示锚点在页尾 */
  .contact-link :global(.down) {
    color: var(--text-3);
    transition: transform 0.25s var(--ease-out), color 0.2s ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .desktop-nav a:hover {
      color: var(--text);
      background: color-mix(in oklch, var(--text) 6%, transparent);
    }

    .nav-drop:hover .menu {
      opacity: 1;
      transform: none;
      pointer-events: auto;
    }

    .nav-drop:hover .trigger :global(.caret) {
      transform: rotate(180deg);
    }

    .contact-link:hover :global(.down) {
      transform: translateY(2px);
      color: var(--accent-strong);
    }
  }

  #theme-toggle {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    background: transparent;
    color: var(--text-2);
    transition: border-color 0.2s ease, color 0.2s ease, transform 0.3s var(--ease-out);
  }

  @media (hover: hover) and (pointer: fine) {
    #theme-toggle:hover {
      color: var(--text);
      border-color: var(--text-3);
      transform: none;
    }
  }

  #theme-toggle:active {
    transform: scale(0.92);
  }

  #theme-toggle .icon-sun,
  #theme-toggle .icon-moon {
    display: inline-flex;
  }

  .icon-moon {
    display: none !important;
  }

  :global([data-theme='dark']) .icon-moon {
    display: inline-flex !important;
  }

  :global([data-theme='dark']) .icon-sun {
    display: none !important;
  }

  .mobile-current,
  #mobile-nav-toggle,
  .mobile-nav-layer {
    display: none;
  }

  .site-header a,
  .site-header button {
    touch-action: manipulation;
    -webkit-user-drag: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-drop .menu {
      transition: opacity 0.18s ease;
      transform: none;
    }
  }

  @media (max-width: 720px), (hover: none) and (pointer: coarse) {
    .site-header,
    .site-header.scrolled,
    .site-header.menu-open {
      background: var(--header-bg);
      -webkit-backdrop-filter: blur(14px);
      backdrop-filter: blur(14px);
      border-bottom-color: var(--border);
    }

    .inner {
      gap: 8px;
    }

    .brand .en,
    .brand .divider {
      display: none;
    }

    .desktop-nav {
      display: none;
    }

    .mobile-current {
      display: block;
      min-width: 0;
      margin-left: auto;
      overflow: hidden;
      color: var(--text-3);
      font-family: var(--font-mono);
      font-size: 11.5px;
      letter-spacing: 0.06em;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    #theme-toggle,
    #mobile-nav-toggle {
      width: 44px;
      height: 44px;
    }

    #mobile-nav-toggle {
      flex: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 1px solid var(--border-strong);
      border-radius: var(--radius);
      background: transparent;
      color: var(--text-2);
    }

    #mobile-nav-toggle:active {
      transform: scale(0.94);
    }

    #mobile-nav-toggle .icon-menu,
    #mobile-nav-toggle .icon-close {
      display: inline-flex;
    }

    #mobile-nav-toggle .icon-close,
    #mobile-nav-toggle[aria-expanded='true'] .icon-menu {
      display: none;
    }

    #mobile-nav-toggle[aria-expanded='true'] .icon-close {
      display: inline-flex;
    }

    .mobile-nav-layer {
      position: absolute;
      inset: 60px 0 auto;
      display: block;
      height: calc(100dvh - 60px);
      visibility: hidden;
      overflow: hidden;
      background: var(--bg);
      opacity: 0;
      pointer-events: none;
      transform: translateY(-8px);
      transition: opacity 0.18s ease, transform 0.18s var(--ease-out), visibility 0.18s;
    }

    .mobile-nav-layer.open {
      visibility: visible;
      opacity: 1;
      pointer-events: auto;
      transform: none;
    }

    .mobile-nav-menu {
      width: min(var(--w-page), 100% - 2 * var(--gutter));
      height: 100%;
      margin-inline: auto;
      padding: 20px 0 max(28px, env(safe-area-inset-bottom));
      overflow-y: auto;
      overscroll-behavior: contain;
      touch-action: pan-y;
      -webkit-overflow-scrolling: touch;
    }

    .mobile-nav-primary {
      border-top: 1px solid var(--border);
    }

    .mobile-nav-primary a {
      display: flex;
      min-height: 56px;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
      border-bottom: 1px solid var(--border);
      color: var(--text-2);
      font-size: 18px;
      font-weight: 600;
    }

    .mobile-nav-primary a .mono-sm {
      color: var(--text-mono);
      font-size: 10.5px;
      font-weight: 400;
      letter-spacing: 0.12em;
    }

    .mobile-nav-primary a.active,
    .mobile-nav-primary a:active {
      color: var(--accent-strong);
    }

    .mobile-home-group {
      padding-top: 26px;
    }

    .mobile-group-label {
      margin-bottom: 10px;
      color: var(--text-mono);
      font-size: 11px;
      letter-spacing: 0.08em;
    }

    .mobile-home-links {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
    }

    .mobile-home-links a {
      display: inline-flex;
      min-height: 48px;
      align-items: center;
      justify-content: center;
      border: 1px solid var(--border-strong);
      border-radius: var(--radius);
      color: var(--text-2);
      font-size: 14px;
    }

    .mobile-home-links a.active,
    .mobile-home-links a:active {
      border-color: var(--accent-border);
      color: var(--accent-strong);
      background: var(--surface-accent);
    }

    :global(html.mobile-nav-open),
    :global(html.mobile-nav-open body) {
      overflow: hidden;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-nav-layer {
      transition: none;
      transform: none;
    }
  }
</style>
