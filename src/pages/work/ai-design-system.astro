    gap: 9px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .ai-btn-w {
    font-size: 12px;
    font-weight: 600;
    color: #4f46e5;
    background: #fff;
    border-radius: 8px;
    padding: 9px 18px;
  }

  .ai-btn-o {
    font-size: 12px;
    font-weight: 600;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: 8px;
    padding: 9px 18px;
  }

  .ai-tiles {
    display: flex;
    gap: 11px;
    padding: 20px 20px 24px;
    background: #fff;
  }

  .ai-tile {
    flex: 1;
    border: 1px solid oklch(0.92 0.004 264);
    border-left-width: 3px;
    border-left-style: solid;
    border-radius: 10px;
    padding: 13px 12px;
  }

  .ai-tile .emoji {
    font-size: 17px;
    margin-bottom: 7px;
  }

  .ai-tile .metric {
    font-size: 15px;
    font-weight: 800;
    color: #4f46e5;
  }

  .ai-tile .desc {
    font-size: 10px;
    color: oklch(0.52 0.012 264);
    margin-top: 2px;
  }

  .anti-caption {
    display: flex;
    gap: 8px;
    align-items: flex-start;
    margin-top: 16px;
  }

  .anti-caption .x {
    color: var(--danger);
    flex-shrink: 0;
  }

  .anti-caption p {
    font-size: 11px;
    line-height: 1.6;
    letter-spacing: 0.02em;
    color: var(--text-3);
  }

  /* ---- 04 框架 ---- */
  .fw-grid {
    display: flex;
    align-items: stretch;
    gap: 14px;
    flex-wrap: wrap;
  }

  .fw-card {
    flex: 1;
    min-width: min(250px, 100%);
    display: flex;
    flex-direction: column;
  }

  .fw-label {
    font-size: 13px;
    letter-spacing: 0.1em;
    margin-bottom: 20px;
  }

  .fw-title {
    font-size: 26px;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin-bottom: 14px;
  }

  .fw-card p {
    font-size: 15px;
    color: var(--text-2);
    margin-bottom: 26px;
  }

  .fw-ref {
    margin-top: auto;
    padding-top: 20px;
    border-top: 1px solid var(--border-subtle);
    color: var(--text-3);
    letter-spacing: 0.02em;
  }

  .fw-arr {
    align-self: center;
    color: var(--text-3);
    font-size: 24px;
  }

  .fw-arr.accent {
    color: var(--accent);
  }

  @media (max-width: 900px) {
    .fw-arr {
      display: none;
    }
  }

  /* ---- 深色分幕 ---- */
  .band-frame {
    background: var(--band-bg);
    border-radius: var(--radius);
    border-bottom: none;
    padding: clamp(40px, 6vw, 72px) clamp(24px, 4.5vw, 60px);
    margin: clamp(44px, 6.5vw, 80px) calc(-1 * clamp(0px, 2vw, 24px));
  }

  .band-head-line {
    border-bottom-color: var(--band-border);
  }

  .on-band {
    color: var(--band-text);
  }

  .on-band-2 {
    color: var(--band-text-2);
  }

  .on-band-accent {
    color: var(--band-accent);
  }

  .band-frame .fen,
  .band-frame .phase {
    color: var(--band-text-3);
  }

  .band-frame .phase b {
    color: var(--band-accent-2);
  }

  .band-frame h2 {
    color: var(--band-text);
  }

  .band-frame .frame-lead {
    color: var(--band-text-2);
  }

  /* ---- 05 三层约束 ---- */
  .goal-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.25fr);
    gap: clamp(30px, 5vw, 64px);
    align-items: center;
  }

  @media (max-width: 900px) {
    .goal-grid {
      grid-template-columns: 1fr;
    }
  }

  .layers {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .layer {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    border: 1px solid var(--band-border);
    border-radius: var(--radius);
    padding: 24px 28px;
    background: var(--band-surface);
  }

  .layer-accent {
    border-color: oklch(0.45 0.13 262);
    background: oklch(0.27 0.05 262);
  }

  .layer-head {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 8px;
  }

  .lk {
    letter-spacing: 0.1em;
    color: var(--band-text-2);
  }

  .layer-accent .lk {
    color: var(--band-accent-2);
  }

  .ln {
    font-size: 17px;
    font-weight: 600;
    color: var(--band-text);
  }

  .layer p {
    font-size: 14px;
    line-height: 1.6;
    color: var(--band-text-2);
  }

  .layer-accent p {
    color: oklch(0.8 0.03 262);
  }

  .meters {
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex-shrink: 0;
    width: 118px;
  }

  .meter-label {
    font-size: 9.5px;
    letter-spacing: 0.08em;
    color: var(--band-text-3);
    margin-bottom: 5px;
  }

  .dots {
    display: flex;
    gap: 5px;
  }

  .pt {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--band-border);
  }

  .pt.on {
    background: var(--band-accent);
  }

  .pt.danger.on {
    background: oklch(0.62 0.13 28);
  }

  .layers-note {
    display: flex;
    gap: 10px;
    align-items: center;
    color: var(--band-text-3);
    letter-spacing: 0.02em;
    margin-top: 4px;
  }

  @media (max-width: 560px) {
    .layer {
      flex-direction: column;
    }

    .meters {
      flex-direction: row;
      width: auto;
      gap: 24px;
    }
  }

  /* ---- 06 工具表 ---- */
  .tool-table {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 38px;
    background: var(--surface);
  }

  .tt-row {
    display: grid;
    grid-template-columns: 180px 130px minmax(0, 1fr);
    gap: 16px;
    padding: 20px 26px;
    border-bottom: 1px solid var(--border-subtle);
    align-items: center;
  }

  .tt-row:last-child {
    border-bottom: none;
  }

  .tt-head {
    padding: 13px 26px;
    background: var(--surface-2);
    border-bottom: 1px solid var(--border);
  }

  .tt-head .mono-label {
    letter-spacing: 0.12em;
  }

  .tt-name {
    font-weight: 500;
    font-size: 14.5px;
    display: flex;
    align-items: center;
    gap: 9px;
    flex-wrap: wrap;
  }

  .tt-check {
    color: var(--accent-strong);
    font-size: 11px;
  }

  .tt-verdict {
    font-size: 13.5px;
    color: var(--danger);
    font-weight: 500;
  }

  .tt-verdict.good {
    color: var(--accent-strong);
    font-weight: 600;
  }

  .tt-why {
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--text-2);
  }

  .tt-row.chosen {
    background: var(--surface-accent);
  }

  .tt-row.chosen .tt-why {
    color: var(--accent-deep);
  }

  @media (max-width: 700px) {
    .tt-row {
      grid-template-columns: 1fr;
      gap: 6px;
    }
  }

  .checks-head {
    display: flex;
    align-items: baseline;
    gap: 14px;
    margin-bottom: 18px;
    flex-wrap: wrap;
  }

  .checks-note {
    font-size: 13px;
    color: var(--text-3);
  }

  .checks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(220px, 100%), 1fr));
    gap: 14px;
  }

  .check {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    padding: 17px 20px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    font-size: 15px;
  }

  /* ---- 07 Origin ---- */
  .origin-intro {
    margin-bottom: 40px;
  }

  .group-label {
    display: block;
    margin-bottom: 16px;
  }

  .lever-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(280px, 100%), 1fr));
    gap: 16px;
    margin-bottom: 44px;
  }

  .lever {
    border: 1px solid var(--accent);
    border-radius: var(--radius);
    padding: 26px 28px;
    background: var(--surface-accent);
  }

  .lever-name {
    font-size: 25px;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--accent-deep);
    margin-bottom: 6px;
  }

  .lever-sub {
    font-size: 14px;
    font-weight: 500;
    color: var(--accent-strong);
    margin-bottom: 12px;
  }

  .lever p {
    font-size: 14px;
    color: var(--text-2);
  }

  .origin-flow {
    display: flex;
    align-items: stretch;
    gap: 14px;
    flex-wrap: wrap;
  }

  .of-step {
    flex: 1;
    min-width: min(220px, 100%);
  }

  .of-step.wide {
    flex: 1.3;
  }

  .of-head {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 12px;
  }

  .of-name {
    font-size: 16px;
    font-weight: 600;
  }

  .of-tool {
    color: var(--accent);
    letter-spacing: 0.08em;
  }

  .of-step p {
    font-size: 13.5px;
    color: var(--text-2);
  }

  .of-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .of-pills .chip {
    font-size: 13px;
  }

  .of-step.dark {
    border: 1px solid var(--band-border);
    border-radius: var(--radius);
    padding: 22px 24px;
    background: var(--band-bg);
    color: var(--band-text);
  }

  .of-step.dark .of-name {
    color: var(--band-text);
  }

  .of-ver {
    color: var(--band-accent);
    letter-spacing: 0.1em;
  }

  .of-step.dark p {
    color: var(--band-text-2);
  }

  /* ---- 08 过拟合 ---- */
  .fit-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(280px, 100%), 1fr));
    gap: 18px;
    align-items: stretch;
  }

  .fit-head {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .fit-tag {
    color: var(--danger);
    letter-spacing: 0.06em;
  }

  .fit-title {
    font-size: 17.5px;
    font-weight: 600;
  }

  .fit-body {
    font-size: 14.5px;
    color: var(--text-2);
    margin-bottom: 24px;
  }

  .wires {
    display: flex;
    gap: 9px;
  }

  .wire {
    flex: 1;
    border: 1px solid var(--border-subtle);
    border-radius: 3px;
    padding: 9px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .w-hero {
    display: block;
    height: 18px;
    border-radius: 2px;
    background: oklch(0.8 0.05 262);
    margin-bottom: 3px;
  }

  .w-hero.soft {
    background: var(--border-strong);
  }

  .w-line {
    display: block;
    height: 5px;
    border-radius: 2px;
    background: var(--border-subtle);
  }

  .w-cols {
    display: flex;
    gap: 4px;
    margin-bottom: 2px;
  }

  .w-cols span {
    flex: 1;
    height: 24px;
    border-radius: 2px;
    background: var(--border-strong);
  }

  .wire-cap {
    margin-top: 10px;
    color: var(--text-mono);
    font-size: 10.5px;
  }

  .principles {
    padding: 28px 30px;
  }

  .p-title {
    color: var(--band-accent) !important;
    letter-spacing: 0.16em;
    margin-bottom: 22px;
  }

  .principles ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .principles li {
    font-size: 14.5px;
    line-height: 1.5;
    color: oklch(0.84 0.008 264);
  }

  .principles b {
    color: #fff;
    font-weight: 500;
  }

  .p-core {
    margin-top: 26px;
    padding-top: 20px;
    border-top: 1px solid var(--band-border);
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--band-text-2);
  }

  /* ---- 09 Loop ---- */
  .loop {
    display: flex;
    align-items: stretch;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 48px;
  }

  .loop-step {
    flex: 1;
    min-width: min(180px, 100%);
  }

  .loop-idx {
    color: var(--band-accent);
    margin-bottom: 12px;
    letter-spacing: 0.08em;
  }

  .loop-step p {
    font-size: 14.5px;
    line-height: 1.6;
    color: oklch(0.86 0.008 264);
  }

  .loop-arr {
    align-self: flex-start;
    padding-top: 2px;
    color: var(--band-text-3);
    font-size: 17px;
  }

  .loop-arr.back {
    color: var(--band-accent);
  }

  @media (max-width: 860px) {
    .loop {
      flex-direction: column;
      gap: 18px;
    }

    .loop-arr {
      display: none;
    }
  }

  .versions {
    padding-top: 40px;
    border-top: 1px solid var(--band-border);
  }

  .v-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }

  .v-rule {
    font-size: 13.5px;
    color: var(--band-text-2);
  }

  .v-line {
    display: flex;
    align-items: center;
    margin-bottom: 26px;
  }

  .v-tag {
    color: var(--band-accent-2);
    font-weight: 500;
    font-size: 15px;
  }

  .v-tag.end {
    font-weight: 600;
  }

  .v-track {
    flex: 1;
    height: 2px;
    background: linear-gradient(to right, oklch(0.45 0.1 262), oklch(0.7 0.15 262));
    margin: 0 16px;
    position: relative;
  }

  .v-node {
    position: absolute;
    top: -3px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--band-bg);
    border: 2px solid oklch(0.62 0.13 262);
    transform: translateX(-50%);
  }

  .v-ps {
    font-size: 13.5px;
    line-height: 1.7;
    color: var(--band-text-3);
    max-width: 84ch;
  }

  .v-ps i {
    color: var(--band-text-2);
  }

  /* ---- 10/12 实例卡 ---- */
  .ex-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(300px, 100%), 1fr));
    gap: 18px;
  }

  .ex-ver {
    font-size: 13px;
    letter-spacing: 0.06em;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .ex-title {
    font-size: 20px;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-bottom: 22px;
  }

  .ex-rows {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .ex-row {
    display: flex;
    gap: 16px;
  }

  .ex-k {
    color: var(--text-mono);
    letter-spacing: 0.06em;
    width: 42px;
    flex-shrink: 0;
    padding-top: 2px;
  }

  .ex-v {
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--text-2);
  }

  .ex-row.verify {
    padding-top: 14px;
    border-top: 1px solid var(--border-subtle);
  }

  .ex-row.verify .ex-k {
    color: var(--accent-strong);
  }

  .ex-row.verify .ex-v {
    color: var(--accent-deep);
    font-weight: 500;
  }

  /* ---- 11 成果 ---- */
  .result-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(240px, 100%), 1fr));
    gap: 20px;
  }

  .r-cap {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-top: 16px;
  }

  .r-zh {
    font-size: 15px;
    font-weight: 500;
  }

  .r-en {
    color: var(--text-mono);
  }

  .r-body {
    font-size: 13.5px;
    color: var(--text-3);
    margin-top: 6px;
  }

  .result-note {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    margin-top: 34px;
    padding-top: 22px;
    border-top: 1px solid var(--border-subtle);
  }

  .result-note .mono-label {
    color: var(--accent-strong);
    padding-top: 3px;
  }

  .result-note p {
    font-size: 14px;
    color: var(--text-2);
    max-width: 80ch;
  }

  /* ---- 12 issues ---- */
  .issue-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 18px;
  }

  .issue-body {
    font-size: 14.5px;
    color: var(--text-2);
    margin-bottom: 26px;
  }

  .issue-plan {
    padding-top: 22px;
    border-top: 1px solid var(--border-subtle);
  }

  .plan-head {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
  }

  .plan-head .mono-label {
    color: var(--accent-strong);
  }

  .issue-plan p {
    font-size: 14px;
    color: var(--text-2);
  }

  /* ---- 转场 ---- */
  .interlude {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: min(72svh, 620px);
  }

  .int-kicker {
    display: flex;
    align-items: center;
    gap: 16px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--band-text-3);
    margin-bottom: 40px;
  }

  .int-line {
    width: 40px;
    height: 1px;
    background: var(--band-border);
  }

  .int-title {
    font-size: clamp(44px, 8vw, 76px);
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--band-accent-2);
    margin-bottom: 32px;
    max-width: none;
  }

  .int-sub {
    font-size: clamp(17px, 2.4vw, 22px);
    line-height: 1.62;
    color: oklch(0.8 0.01 264);
    max-width: 34em;
  }

  .int-sub b {
    color: #fff;
    font-weight: 500;
  }

  /* ---- 13 复用 ---- */
  .quote {
    font-size: 13px;
    letter-spacing: 0.02em;
    margin-bottom: 16px;
  }

  .reuse-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(300px, 100%), 1fr));
    gap: 18px;
    margin-bottom: 36px;
  }

  .ru-label {
    letter-spacing: 0.1em;
    margin-bottom: 18px;
  }

  .ru-label.accent {
    color: var(--accent-strong);
  }

  .ru-title {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 18px;
  }

  .reuse-hi {
    border-color: var(--accent);
    background: var(--surface-accent);
  }

  .ru-flow {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    color: var(--text-3);
  }

  .ru-pill {
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 6px 10px;
    color: var(--text-2);
  }

  .ru-pill.hi {
    border-color: var(--accent-border);
    background: var(--surface);
    color: var(--accent-deep);
  }

  .reuse-line {
    font-size: clamp(17px, 2.4vw, 23px);
    line-height: 1.55;
    font-weight: 500;
    letter-spacing: -0.01em;
    max-width: 40em;
  }

  /* ---- 14 收尾 ---- */
  .closing .cover-top {
    margin-bottom: clamp(32px, 5vw, 56px);
  }

  .insights {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(260px, 100%), 1fr));
    gap: 0;
    margin: clamp(36px, 5vw, 56px) 0;
  }

  .ins {
    padding: 0 clamp(24px, 4vw, 48px);
    border-left: 1px solid var(--border);
  }

  .ins:first-child {
    padding-left: 0;
    border-left: none;
  }

  .ins .mono-accent {
    display: block;
    font-size: 12px;
    margin-bottom: 16px;
  }

  .ins p {
    font-size: 15.5px;
    line-height: 1.74;
    color: var(--text);
  }

  @media (max-width: 860px) {
    .ins {
      border-left: none;
      padding: 20px 0;
      border-top: 1px solid var(--border);
    }

    .ins:first-child {
      border-top: none;
      padding-top: 0;
    }
  }

  .final {
    padding-top: clamp(32px, 5vw, 48px);
    border-top: 1px solid var(--border-strong);
  }

  .final p {
