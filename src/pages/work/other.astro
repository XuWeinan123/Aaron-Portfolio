---
import CaseLayout from '../../layouts/CaseLayout.astro';
import SectionHead from '../../components/SectionHead.astro';
import MediaSlot from '../../components/MediaSlot.astro';
---

<CaseLayout
  title="其他作品 - 徐炜楠"
  description="Figma 插件、面向设计师的技术分享、动效设计。"
  index="OTHER WORK"
  category="插件 · 分享 · 动效"
  heading="其他作品"
  summary="我开发了一些 Figma 插件，受到了广泛的欢迎；之前进行过多场面向设计师的技术分享，反馈都不错；还在 OPPO 动效团队工作过，喜欢用动效实现微交互。"
>
  <!-- 概览媒体 -->
  <div class="container case-section">
    <div class="pair">
      <div class="reveal"><MediaSlot label="作品概览视觉 A" node="539:9165" ratio="16 / 10" /></div>
      <div class="reveal" style="--d:.08s">
        <MediaSlot label="作品概览视觉 B" node="539:9167" ratio="16 / 10" />
      </div>
    </div>
  </div>

  <!-- 01 Figma 插件 -->
  <section id="plugin" class="container case-section">
    <SectionHead num="01" zh="Figma 插件" en="Figma Plugin">
      <span slot="side" class="mono-sm side-note">≈ 6K USERS</span>
    </SectionHead>
    <div class="split">
      <div class="reveal">
        <h3 class="split-title">减少无意义工作，专注设计本身</h3>
        <p class="split-body">
          在日常碰到重复性较强的工作时，我会将其中可以自动化的部分拆离出来，使用代码自动完成。
        </p>
        <p class="split-body">
          减少枯燥的低级工作，聚焦创新，更能发挥设计师的核心价值。
        </p>
      </div>
      <div class="reveal" style="--d:.1s">
        <MediaSlot label="Figma 插件视觉" node="539:9154" ratio="16 / 10" />
      </div>
    </div>
  </section>

  <!-- 02 技术分享 -->
  <section id="presentation" class="container case-section">
    <SectionHead num="02" zh="技术分享" en="Presentation" />
    <div class="split rev">
      <div class="reveal">
        <h3 class="split-title">分享设计师感兴趣的开发知识</h3>
        <p class="split-body">
          我尝试将自己所了解的开发知识进行整理，并用一种生动有趣但又简单的方式描述出来，有效帮助团队内设计师提升沟通水平。
        </p>
        <div class="labels">
          <span class="chip">部门内分享</span>
          <span class="chip">外部网站数据</span>
        </div>
        <a class="series-link mono-sm" href="/blog/">
          博客里有「写给设计师的开发知识」系列 →
        </a>
      </div>
      <div class="media-stack reveal" style="--d:.1s">
        <MediaSlot label="分享现场视觉" node="539:9138" ratio="16 / 9" />
        <div class="pair">
          <MediaSlot label="站内数据 A" node="539:9142" ratio="4 / 3" />
          <MediaSlot label="站内数据 B" node="539:9143" ratio="4 / 3" />
        </div>
      </div>
    </div>
  </section>

  <!-- 03 动效设计 -->
  <section id="motion" class="container case-section">
    <SectionHead num="03" zh="动效设计" en="Motion Design" />
    <div class="motion-head reveal">
      <h3 class="split-title">将动效作为体验设计的重要一环</h3>
      <p class="split-body wide">
        在设计方案建立初期，就会将动效能带来的体验提示优先思考。用动效去营造整个产品的「世界观」，向用户传递设计理念。
      </p>
    </div>
    <div class="motion-grid">
      {
        ['539:9121', '539:9122', '539:9123', '539:9124', '539:9125', '539:9126'].map(
          (node, i) => (
            <div class="reveal" style={`--d:${i * 0.05}s`}>
              <MediaSlot label={`动效示例 ${i + 1}`} node={node} ratio="1 / 1" />
            </div>
          )
        )
      }
    </div>
  </section>

  <a slot="next" class="card next-card" href="/blog/">
    <div>
      <div class="hint">Blog</div>
      <div class="name">去博客看看 —— 设计、开发与 AI 的研究笔记</div>
    </div>
    <span class="go" aria-hidden="true">→</span>
  </a>
</CaseLayout>

<style>
  .pair {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(260px, 100%), 1fr));
    gap: 16px;
  }

  .side-note {
    color: var(--accent-strong);
    letter-spacing: 0.14em;
  }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.3fr);
    gap: clamp(28px, 5vw, 64px);
    align-items: center;
  }

  .split.rev {
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.3fr);
  }

  @media (max-width: 780px) {
    .split,
    .split.rev {
      grid-template-columns: 1fr;
    }
  }

  .split-title {
    font-size: clamp(21px, 3vw, 26px);
    margin-bottom: 16px;
  }

  .split-body {
    color: var(--text-2);
    font-size: 15.5px;
    margin-bottom: 0.9em;
    max-width: 52ch;
  }

  .split-body.wide {
    max-width: 64ch;
  }

  .labels {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin: 20px 0 24px;
  }

  .series-link {
    color: var(--accent-strong);
    letter-spacing: 0.04em;
  }

  .series-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .media-stack {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .motion-head {
    margin-bottom: 34px;
  }

  .motion-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(180px, 100%), 1fr));
    gap: 14px;
  }
</style>
