---
import { cases } from '../data/cases';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="top">
      <div class="left">
        <div class="thanks mono-sm">THANKS FOR WATCHING</div>
        <div class="by">By Aaron Xu · 徐炜楠</div>
        <nav class="mini-nav" aria-label="页脚站点导航">
          <a href="/">首页</a>
          <a href="/blog/">博客</a>
          <a href="/skills/">Skill</a>
          <a href="/products/">产品</a>
          <a href="/design/">组件</a>
          <a href="/#contact">联系我</a>
        </nav>
      </div>
      <nav class="links" aria-label="页脚案例与外部链接">
        <div class="col">
          <div class="mono-label">Case Studies</div>
          {cases.map((c) => <a href={`/work/${c.slug}/`}>{c.footerLabel}</a>)}
        </div>
        <div class="col">
          <div class="mono-label">Elsewhere</div>
          <a href="mailto:woshixwn@gmail.com">woshixwn@gmail.com</a>
          <a href="https://www.xuweinan.com/" target="_blank" rel="noopener">xuweinan.com ↗</a>
          <a
            href="https://www.figma.com/design/cpxGuEaNoMIHF4IZcmbUfx/Playground?node-id=539-385"
            target="_blank"
            rel="noopener">Figma Playground ↗</a
          >
        </div>
      </nav>
    </div>
    <div class="bottom">
      <span class="mono-sm">© {year} 徐炜楠 · Aaron Xu</span>
      <span class="mono-sm note">UX Engineer · Design with Code, Think with AI</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: clamp(72px, 10vw, 128px);
    border-top: 1px solid var(--border);
    background: var(--surface);
    transition: background-color 0.35s ease;
  }

  .top {
    display: flex;
    justify-content: space-between;
    gap: 48px;
    padding: clamp(44px, 6vw, 72px) 0 clamp(32px, 5vw, 56px);
    flex-wrap: wrap;
  }

  .thanks {
    letter-spacing: 0.22em;
    color: var(--text-mono);
    margin-bottom: 14px;
  }

  .by {
    font-size: 21px;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .mini-nav {
    display: flex;
    gap: 18px;
    margin-top: 22px;
  }

  .mini-nav a {
    font-size: 14px;
    color: var(--text-2);
    transition: color 0.2s ease;
  }

  .mini-nav a:hover {
    color: var(--accent-strong);
  }

  .links {
    display: flex;
    gap: clamp(32px, 6vw, 80px);
    flex-wrap: wrap;
  }

  .col {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .col .mono-label {
    margin-bottom: 6px;
  }

  .col a {
    font-size: 14px;
    color: var(--text-2);
    transition: color 0.2s ease;
    width: fit-content;
  }

  .col a:hover {
    color: var(--accent-strong);
  }

  .bottom {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    padding: 22px 0 30px;
    border-top: 1px solid var(--border-subtle);
    color: var(--text-3);
  }

  .bottom .mono-sm {
    font-size: 11.5px;
    letter-spacing: 0.06em;
  }
</style>
