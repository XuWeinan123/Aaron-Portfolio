---
/**
 * 标点修正 · Punct Fixer —— 第一个 PWA 小工具。
 *
 * 独立于站点壳(不用 Base 布局):PWA 以 standalone 打开时不应出现站点导航。
 * 逻辑与 scripts/fix-punct.mjs 保持一致:CJK 后的半角标点 → 全角、含中文的半角括号对 → 全角。
 * manifest / service worker / 图标在 public/tools/punct/ 下,SW 作用域即 /tools/punct/。
 */
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content="把紧跟在中文后的半角标点一键转为全角,离线可用的 PWA 小工具。" />
    <meta name="theme-color" content="#3e63dd" />
    <link rel="manifest" href="/tools/punct/manifest.webmanifest" />
    <link rel="icon" href="/tools/punct/icon-192.png" type="image/png" />
    <link rel="apple-touch-icon" href="/tools/punct/icon-192.png" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="标点修正" />
    <title>标点修正 · Punct Fixer</title>
    <script is:inline>
      (() => {
        const saved = localStorage.getItem('theme');
        document.documentElement.dataset.theme =
          saved === 'light' || saved === 'dark'
            ? saved
            : matchMedia('(prefers-color-scheme: dark)').matches
              ? 'dark'
              : 'light';
      })();
    </script>
  </head>
  <body>
    <div class="app">
      <header>
        <a class="back mono" href="/products/">← 产品</a>
        <h1>标点<span class="accent">修正</span></h1>
        <p class="sub">中文后的半角标点 <span class="mono">, : ; ! ? ( )</span> → 全角。纯本地处理，离线可用。</p>
      </header>

      <label class="visually-hidden" for="src">待修正的文本</label>
      <textarea
        id="src"
        placeholder="粘贴或输入中文文案,例如:设计,是把想法变成体验(用户的体验)!"
        autocomplete="off"
        autocapitalize="off"
        spellcheck="false"></textarea>

      <div class="bar">
        <button id="fix" class="primary" type="button">修正</button>
        <button id="paste" type="button">粘贴</button>
        <button id="copy" type="button">复制结果</button>
        <button id="clear" type="button">清空</button>
        <output id="stat" class="mono" for="src"></output>
      </div>

      <footer class="mono">
        <span>PUNCT FIXER · XUWEINAN.COM</span>
        <span id="pwa-hint">在浏览器分享菜单选「添加到主屏幕」即可离线使用</span>
      </footer>
    </div>

    <script is:inline>
      // 与 scripts/fix-punct.mjs 同一套规则
      const CJK = /[　-ヿ㐀-鿿豈-﫿！-｠「」『』…—·]/;
      const MAP = { ',': '，', ':': '：', ';': '；', '!': '！', '?': '？' };

      const fixText = (src) => {
        let out = '';
        let count = 0;
        for (let i = 0; i < src.length; i++) {
          const ch = src[i];
          if (MAP[ch] && i > 0 && CJK.test(src[i - 1])) {
            out += MAP[ch];
            count++;
          } else {
            out += ch;
          }
        }
        out = out.replace(/\(([^()\n]*)\)/g, (m, inner) =>
          CJK.test(inner) ? (count++, `（${inner}）`) : m
        );
        return { out, count };
      };

      const $ = (id) => document.getElementById(id);
      const src = $('src');
      const stat = $('stat');
      const say = (msg) => {
        stat.textContent = msg;
        clearTimeout(say.t);
        say.t = setTimeout(() => (stat.textContent = ''), 2400);
      };

      $('fix').addEventListener('click', () => {
        const { out, count } = fixText(src.value);
        src.value = out;
        say(count > 0 ? `已修正 ${count} 处` : '没有需要修正的标点');
      });

      $('copy').addEventListener('click', async () => {
        if (!src.value) return say('内容为空');
        try {
          await navigator.clipboard.writeText(src.value);
          say('已复制');
        } catch {
          src.select();
          document.execCommand('copy');
          say('已复制');
        }
      });

      $('paste').addEventListener('click', async () => {
        try {
          const text = await navigator.clipboard.readText();
          if (text) {
            src.value = text;
            say('已粘贴,点「修正」');
          }
        } catch {
          say('请长按输入框手动粘贴');
        }
        src.focus();
      });

      $('clear').addEventListener('click', () => {
        src.value = '';
        src.focus();
      });

      // 返回上一级:来自站内时走 history.back(离线/PWA 下依然可用),
      // 直接打开本页时按 href 正常跳转 /tools/
      document.querySelector('.back').addEventListener('click', (e) => {
        if (history.length > 1 && document.referrer.startsWith(location.origin)) {
          e.preventDefault();
          history.back();
        }
      });

      // 已安装(standalone 打开)就不再提示添加主屏幕
      if (matchMedia('(display-mode: standalone)').matches || navigator.standalone) {
        $('pwa-hint').textContent = '已安装为 App';
      }

      if ('serviceWorker' in navigator) {
        addEventListener('load', () => {
          navigator.serviceWorker.register('/tools/punct/sw.js');
        });
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg: oklch(0.972 0.004 264);
    --surface: oklch(1 0 0);
    --border: oklch(0.9 0.005 264);
    --border-strong: oklch(0.86 0.006 264);
    --text: oklch(0.24 0.01 264);
    --text-2: oklch(0.45 0.012 264);
    --text-mono: oklch(0.55 0.01 264);
    --accent: oklch(0.58 0.18 262);
    --accent-strong: oklch(0.52 0.14 262);
    --radius: 4px;
    --radius-lg: 6px;
    --ease-out: cubic-bezier(0.22, 1, 0.36, 1);
  }

  [data-theme='dark'] {
    --bg: oklch(0.185 0.014 264);
    --surface: oklch(0.205 0.012 264);
    --border: oklch(0.29 0.012 264);
    --border-strong: oklch(0.37 0.012 264);
    --text: oklch(0.93 0.005 264);
    --text-2: oklch(0.72 0.01 264);
    --text-mono: oklch(0.58 0.012 264);
    --accent: oklch(0.7 0.15 262);
    --accent-strong: oklch(0.78 0.12 262);
    color-scheme: dark;
  }

  * {
    margin: 0;
    box-sizing: border-box;
  }

  html,
  body {
    height: 100%;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family:
      'Inter Variable',
      -apple-system,
      'PingFang SC',
      'Noto Sans SC',
      sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  .mono {
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 12px;
    letter-spacing: 0.06em;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
  }

  .app {
    max-width: 720px;
    min-height: 100%;
    margin: 0 auto;
    padding: calc(18px + env(safe-area-inset-top)) 20px calc(18px + env(safe-area-inset-bottom));
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  header .back {
    color: var(--text-mono);
    text-decoration: none;
  }

  header .back:hover {
    color: var(--accent-strong);
  }

  h1 {
    margin-top: 10px;
    font-size: clamp(28px, 6vw, 36px);
    font-weight: 650;
    letter-spacing: -0.02em;
  }

  h1 .accent {
    color: var(--accent-strong);
  }

  .sub {
    margin-top: 6px;
    color: var(--text-2);
    font-size: 14px;
    line-height: 1.7;
  }

  textarea {
    flex: 1;
    min-height: 40vh;
    padding: 14px;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    background: var(--surface);
    color: var(--text);
    font: inherit;
    font-size: 15px;
    line-height: 1.8;
    resize: vertical;
  }

  textarea:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 1px;
  }

  .bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
  }

  button {
    padding: 9px 16px;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    background: var(--surface);
    color: var(--text);
    font: inherit;
    font-size: 14px;
    cursor: pointer;
    transition: border-color 0.2s ease, transform 0.15s ease;
  }

  button:hover {
    border-color: var(--accent);
  }

  button:active {
    transform: scale(0.96);
  }

  button.primary {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
    font-weight: 550;
  }

  button.primary:hover {
    background: var(--accent-strong);
  }

  #stat {
    margin-left: auto;
    color: var(--accent-strong);
  }

  footer {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 6px;
    color: var(--text-mono);
    border-top: 1px solid var(--border);
    padding-top: 12px;
  }

  /* 进入动效:上移 + 淡入,50ms 级联;只动 transform/opacity */
  @keyframes enter {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
  }

  header,
  textarea,
  .bar,
  footer {
    animation: enter 0.35s var(--ease-out) backwards;
  }

  textarea {
    animation-delay: 50ms;
  }

  .bar {
    animation-delay: 100ms;
  }

  footer {
    animation-delay: 150ms;
  }

  @media (prefers-reduced-motion: reduce) {
    button:active {
      transform: none;
    }

    /* 降级为纯淡入,不做位移 */
    @keyframes enter {
      from {
        opacity: 0;
        transform: none;
      }
    }
  }
</style>
