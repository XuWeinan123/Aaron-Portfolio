---
import { FLYPY_KEYS } from '../../lib/flypy-core.mjs';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta
      name="description"
      content="只练小鹤双拼。支持实体键盘与可收起的触屏软键盘，自定义中文文本，离线可用。"
    />
    <meta name="theme-color" content="#f5f0df" />
    <link rel="manifest" href="/tools/flypy/manifest.webmanifest" />
    <link rel="icon" href="/tools/flypy/icon-192.png" type="image/png" />
    <link rel="apple-touch-icon" href="/tools/flypy/icon-192.png" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="小鹤双拼" />
    <title>小鹤双拼练习器 · Flypy Trainer</title>
  </head>
  <body>
    <div class="app" id="app">
      <header class="topbar">
        <a class="back" href="/products/" aria-label="返回造物页">
          <span aria-hidden="true">←</span><span class="back-label">造物</span>
        </a>
        <div class="brand">
          <span class="brand-dot" aria-hidden="true"></span>
          <span>小鹤双拼练习器</span>
        </div>
        <div class="top-actions">
          <button class="quiet" id="install" type="button">安装应用</button>
          <button class="quiet" id="open-settings" type="button">设置</button>
        </div>
      </header>

      <main>
        <section class="scoreboard" aria-label="练习数据">
          <div class="score">
            <span>字 / 分</span>
            <output id="cpm">0</output>
          </div>
          <div class="score">
            <span>准确率</span>
            <output id="accuracy">100%</output>
          </div>
          <div class="score score-time">
            <span>用时</span>
            <output id="elapsed">00:00</output>
          </div>
          <button id="reset" class="reset" type="button">重新开始</button>
        </section>

        <section class="practice" aria-labelledby="practice-title">
          <h1 id="practice-title" class="visually-hidden">小鹤双拼练习</h1>
          <div class="focus-card" aria-live="polite">
            <div class="focus-copy">
              <span class="eyebrow">当前汉字</span>
              <strong id="focus-char">…</strong>
              <span id="focus-pinyin">正在加载</span>
            </div>
            <div class="code" id="focus-code" aria-label="当前汉字双拼编码"></div>
          </div>

          <div class="text-wrap">
            <div id="practice-text" class="practice-text" aria-label="练习文本">正在获取一言…</div>
          </div>

          <p class="quote-source" id="quote-source" hidden></p>

          <p class="instruction" id="instruction" role="status" aria-live="polite">
            点击下方按键，或直接使用英文键盘输入。
          </p>
        </section>
      </main>

      <section class="keyboard-dock" id="keyboard-dock" aria-label="小鹤双拼软键盘">
        <button
          class="keyboard-toggle"
          id="keyboard-toggle"
          type="button"
          aria-expanded="true"
          aria-controls="keyboard-panel">
          <span id="keyboard-toggle-label">收起软键盘</span>
          <span class="chevron" aria-hidden="true"></span>
        </button>
        <div class="keyboard-panel" id="keyboard-panel">
          <div class="keyboard">
            {
              FLYPY_KEYS.map((row) => (
                <div class="key-row">
                  {row.map(([key, hint]) => (
                    <button
                      class="key"
                      type="button"
                      data-key={key}
                      aria-label={`按键 ${key.toUpperCase()}，对应 ${hint}`}>
                      <strong>{key.toUpperCase()}</strong>
                      <span>{hint}</span>
                    </button>
                  ))}
                </div>
              ))
            }
          </div>
          <p class="keyboard-note">英文模式 · 绿色是下一键 · 输错后当前音节重来</p>
        </div>
      </section>

      <div class="toast" id="toast" role="status" aria-live="polite" hidden></div>
    </div>

    <dialog id="settings-dialog" class="dialog">
      <form method="dialog" class="dialog-card" id="settings-form">
        <div class="dialog-head">
          <div>
            <span class="eyebrow">练习设置</span>
            <h2>用自己的文字练习</h2>
          </div>
          <button class="icon-button" value="cancel" aria-label="关闭设置">×</button>
        </div>
        <label for="custom-text">自定义练习文本</label>
        <textarea
          id="custom-text"
          maxlength="1000"
          rows="7"
          placeholder="粘贴一段中文，最多 1000 字。标点会保留显示，但不需要输入。"></textarea>
        <div class="textarea-meta">
          <span id="settings-error" role="alert"></span>
          <span><output id="char-count">0</output> / 1000</span>
        </div>
        <div class="random-setting">
          <div>
            <strong>随机字序</strong>
            <small id="random-help">仅用于自定义文本，每次开始都会重新打乱。</small>
          </div>
          <label class="switch" for="randomize">
            <input id="randomize" type="checkbox" role="switch" aria-describedby="random-help" />
            <span aria-hidden="true"></span>
            <span class="visually-hidden">随机打乱自定义文本字序</span>
          </label>
        </div>
        <div class="best-card">
          <div>
            <span>本机最佳速度</span>
            <strong><output id="best-cpm">—</output> 字 / 分</strong>
          </div>
          <button id="clear-score" class="text-button" type="button">清除本机成绩</button>
        </div>
        <div class="dialog-actions">
          <button id="restore-default" class="secondary" type="button">恢复内置文本</button>
          <button id="start-custom" class="primary" type="button">开始练习</button>
        </div>
        <p class="privacy">自定义文字只在当前设备处理与保存，不会上传。</p>
      </form>
    </dialog>

    <dialog id="summary-dialog" class="dialog summary-dialog">
      <div class="dialog-card">
        <span class="eyebrow">本段完成</span>
        <h2>节奏已经记住了</h2>
        <div class="summary-grid">
          <div><span>速度</span><strong id="summary-cpm">0</strong><small>字 / 分</small></div>
          <div><span>准确率</span><strong id="summary-accuracy">100%</strong></div>
          <div><span>用时</span><strong id="summary-time">00:00</strong></div>
          <div><span>错键</span><strong id="summary-errors">0</strong><small>次</small></div>
        </div>
        <p id="best-message" class="best-message"></p>
        <div class="dialog-actions">
          <button id="repeat" class="secondary" type="button">再练一次</button>
          <button id="next" class="primary next-button" type="button" autofocus>
            <span>下一段</span><kbd>Space</kbd>
          </button>
        </div>
      </div>
    </dialog>

    <script>
      import {
        FALLBACK_TEXTS,
        createSession,
        formatElapsed,
        getCurrentUnit,
        getMetrics,
        inputKey,
      } from '../../lib/flypy-core.mjs';

      const HITOKOTO_URL = 'https://v1.hitokoto.cn/?encode=json&max_length=60';
      const STORAGE = {
        customText: 'flypy:custom-text',
        keyboardOpen: 'flypy:keyboard-open',
        randomize: 'flypy:randomize',
        quoteQueue: 'flypy:hitokoto-queue',
        best: 'flypy:best',
      };
      const $ = (id) => document.getElementById(id);
      const app = $('app');
      const practiceText = $('practice-text');
      const focusChar = $('focus-char');
      const focusPinyin = $('focus-pinyin');
      const focusCode = $('focus-code');
      const instruction = $('instruction');
      const quoteSource = $('quote-source');
      const settingsDialog = $('settings-dialog');
      const summaryDialog = $('summary-dialog');
      const customText = $('custom-text');
      const randomizeInput = $('randomize');
      const nextButton = $('next');
      const keyButtons = [...document.querySelectorAll('[data-key]')];
      const fallbackQuotes = FALLBACK_TEXTS.map((text, index) => ({
        text,
        from: '离线备用',
        fromWho: '',
        uuid: `fallback-${index}`,
      }));

      let activeCustomText = localStorage.getItem(STORAGE.customText) ?? '';
      let randomizeCustom = localStorage.getItem(STORAGE.randomize) === 'true';
      let activeMode = activeCustomText ? 'custom' : 'hitokoto';
      let activeText = activeCustomText;
      let activeQuote = null;
      let session = null;
      let completionShown = false;
      let toastTimer;
      let queueRetryTimer;
      let queueTask = Promise.resolve();

      const wait = (duration) => new Promise((resolve) => setTimeout(resolve, duration));
      const normalizeQuote = (item) => {
        if (typeof item === 'string') return { text: item, from: '', fromWho: '', uuid: '' };
        if (!item || typeof item.text !== 'string') return null;
        return {
          text: item.text.trim(),
          from: String(item.from ?? ''),
          fromWho: String(item.fromWho ?? ''),
          uuid: String(item.uuid ?? ''),
        };
      };
      const readQuoteQueue = () => {
        try {
          const parsed = JSON.parse(localStorage.getItem(STORAGE.quoteQueue));
          if (!Array.isArray(parsed)) return [];
          return parsed
            .map(normalizeQuote)
            .filter((item) => item?.text && !item.uuid.startsWith('fallback-'))
            .slice(0, 6);
        } catch {
          return [];
        }
      };
      const saveQuoteQueue = (queue) => {
        localStorage.setItem(STORAGE.quoteQueue, JSON.stringify(queue.slice(0, 6)));
      };
      const withQueueLock = (operation) => {
        const next = queueTask.then(operation, operation);
        queueTask = next.catch(() => undefined);
        return next;
      };

      const fetchHitokoto = async () => {
        const controller = new AbortController();
        const timeout = setTimeout(() => controller.abort(), 6500);
        try {
          const response = await fetch(HITOKOTO_URL, { cache: 'no-store', signal: controller.signal });
          if (!response.ok) throw new Error(`一言接口返回 ${response.status}`);
          const data = await response.json();
          const text = String(data.hitokoto ?? '').trim();
          createSession(text);
          return {
            text,
            from: String(data.from ?? ''),
            fromWho: String(data.from_who ?? ''),
            uuid: String(data.uuid ?? ''),
          };
        } finally {
          clearTimeout(timeout);
        }
      };

      const ensureQuoteQueue = async (target = 3, allowFallback = false) => {
        let attempts = 0;
        while (readQuoteQueue().length < target && attempts < target * 2) {
          attempts++;
          try {
            const quote = await fetchHitokoto();
            const queue = readQuoteQueue();
            if (!queue.some((item) => item.uuid === quote.uuid || item.text === quote.text)) queue.push(quote);
            saveQuoteQueue(queue);
            if (queue.length < target) await wait(550);
          } catch {
            break;
          }
        }
        const queue = readQuoteQueue();
        saveQuoteQueue(queue);
        return queue.length || !allowFallback ? queue : [fallbackQuotes[0]];
      };

      const refillQuoteQueue = () =>
        withQueueLock(() => ensureQuoteQueue(3)).finally(() => {
          clearTimeout(queueRetryTimer);
          if (activeMode === 'hitokoto' && readQuoteQueue().length < 3) {
            queueRetryTimer = setTimeout(() => {
              if (activeMode === 'hitokoto') void refillQuoteQueue();
            }, 10_000);
          }
        });
      const takeNextQuote = async () => {
        const cached = readQuoteQueue();
        if (cached.length) {
          const quote = cached.shift();
          saveQuoteQueue(cached);
          void refillQuoteQueue();
          return quote;
        }

        return withQueueLock(async () => {
          const queue = await ensureQuoteQueue(1, true);
          const quote = queue.shift() ?? fallbackQuotes[0];
          saveQuoteQueue(queue);
          void refillQuoteQueue();
          return quote;
        });
      };

      const getBest = () => {
        try {
          return JSON.parse(localStorage.getItem(STORAGE.best)) ?? null;
        } catch {
          return null;
        }
      };

      const showToast = (message) => {
        const toast = $('toast');
        toast.textContent = message;
        toast.hidden = false;
        clearTimeout(toastTimer);
        toastTimer = setTimeout(() => (toast.hidden = true), 4200);
      };

      const renderLoading = () => {
        session = null;
        focusChar.textContent = '…';
        focusPinyin.textContent = '正在加载';
        focusCode.replaceChildren();
        practiceText.textContent = '正在准备下一句…';
        quoteSource.hidden = true;
        instruction.textContent = '首次进入会缓存三句，之后每完成一句补充一句。';
        keyButtons.forEach((button) => {
          button.disabled = true;
          button.classList.remove('target', 'wrong', 'pressed');
        });
        $('cpm').textContent = '0';
        $('accuracy').textContent = '100%';
        $('elapsed').textContent = '00:00';
      };

      const renderText = () => {
        if (!session) return;
        const current = getCurrentUnit(session);
        const currentIndex = current?.index ?? Infinity;
        practiceText.replaceChildren(
          ...session.units.map((unit) => {
            const span = document.createElement('span');
            span.textContent = unit.char;
            span.className = 'unit';
            if (!unit.practice) span.classList.add('passive');
            if (unit.index < currentIndex || session.status === 'complete') span.classList.add('done');
            if (unit.index === currentIndex) {
              span.classList.add('current');
              span.setAttribute('aria-current', 'true');
            }
            return span;
          })
        );
      };

      const renderFocus = () => {
        if (!session) return;
        const current = getCurrentUnit(session);
        if (!current) return;
        focusChar.textContent = current.char;
        focusPinyin.textContent = current.pinyin;
        focusCode.replaceChildren(
          ...[...current.code].map((key, index) => {
            const chip = document.createElement('span');
            chip.textContent = key.toUpperCase();
            chip.className = 'code-chip';
            if (index < session.keyIndex) chip.classList.add('done');
            if (index === session.keyIndex) chip.classList.add('current');
            return chip;
          })
        );
        const expected = current.code[session.keyIndex];
        keyButtons.forEach((button) => {
          button.disabled = false;
          button.classList.toggle('target', button.dataset.key === expected);
          button.classList.remove('wrong', 'pressed');
        });
      };

      const renderStats = () => {
        if (!session) return;
        const metrics = getMetrics(session);
        $('cpm').textContent = String(Math.round(metrics.cpm));
        $('accuracy').textContent = `${Math.round(metrics.accuracy)}%`;
        $('elapsed').textContent = formatElapsed(metrics.elapsedMs);
      };

      const renderQuoteSource = () => {
        if (activeMode !== 'hitokoto' || !activeQuote) {
          quoteSource.hidden = true;
          return;
        }
        const source = activeQuote.from ? `来自《${activeQuote.from}》` : '随机一言';
        const author = activeQuote.fromWho ? ` · ${activeQuote.fromWho}` : '';
        const link = document.createElement('a');
        link.href = activeQuote.uuid ? `https://hitokoto.cn/?uuid=${activeQuote.uuid}` : 'https://hitokoto.cn/';
        link.target = '_blank';
        link.rel = 'noopener noreferrer';
        link.textContent = '一言';
        quoteSource.replaceChildren(document.createTextNode(`${source}${author} · `), link);
        quoteSource.hidden = false;
      };

      const render = () => {
        renderText();
        renderFocus();
        renderStats();
        renderQuoteSource();
      };

      const saveBest = (metrics) => {
        const previous = getBest();
        const candidate = {
          cpm: Math.round(metrics.cpm),
          accuracy: Math.round(metrics.accuracy),
          date: new Date().toISOString(),
        };
        const isNew = !previous || candidate.cpm > previous.cpm;
        if (isNew) localStorage.setItem(STORAGE.best, JSON.stringify(candidate));
        return isNew;
      };

      const showSummary = () => {
        if (completionShown || !session) return;
        completionShown = true;
        const metrics = getMetrics(session);
        $('summary-cpm').textContent = String(Math.round(metrics.cpm));
        $('summary-accuracy').textContent = `${Math.round(metrics.accuracy)}%`;
        $('summary-time').textContent = formatElapsed(metrics.elapsedMs);
        $('summary-errors').textContent = String(session.errors);
        const isNewBest = saveBest(metrics);
        $('best-message').textContent = isNewBest ? '新的本机速度纪录。' : '保持准确，速度会自然跟上。';
        nextButton.disabled = false;
        summaryDialog.showModal();
        requestAnimationFrame(() => nextButton.focus());
      };

      const flashKey = (key, state) => {
        const button = keyButtons.find((item) => item.dataset.key === key);
        if (!button) return;
        button.classList.add(state === 'error' ? 'wrong' : 'pressed');
      };

      const handleKey = (key) => {
        if (!session || settingsDialog.open || summaryDialog.open || session.status === 'complete') return;
        const previous = session;
        session = inputKey(session, key);
        if (session === previous) return;
        instruction.textContent =
          session.lastInput === 'error' ? '这个音节从第一键重来。' : '很好，继续保持节奏。';
        render();
        flashKey(key, session.lastInput);
        if (session.status === 'complete') setTimeout(showSummary, 260);
      };

      const restart = (text = activeText) => {
        activeText = text;
        session = createSession(activeText, {
          randomize: activeMode === 'custom' && randomizeCustom,
        });
        completionShown = false;
        instruction.textContent = '点击下方按键，或直接使用英文键盘输入。';
        render();
      };

      const startBuiltIn = async () => {
        activeMode = 'hitokoto';
        activeQuote = null;
        renderLoading();
        activeQuote = await takeNextQuote();
        restart(activeQuote.text);
      };

      keyButtons.forEach((button) => button.addEventListener('click', () => handleKey(button.dataset.key)));

      addEventListener('keydown', (event) => {
        if (summaryDialog.open && event.code === 'Space') {
          event.preventDefault();
          if (!event.repeat) nextButton.click();
          return;
        }
        if (
          event.repeat ||
          event.isComposing ||
          event.metaKey ||
          event.ctrlKey ||
          event.altKey ||
          event.target instanceof HTMLTextAreaElement ||
          event.target instanceof HTMLInputElement
        )
          return;
        if (/^[a-z]$/i.test(event.key)) {
          event.preventDefault();
          handleKey(event.key);
        }
      });

      $('reset').addEventListener('click', () => session && restart());
      $('repeat').addEventListener('click', () => {
        summaryDialog.close();
        restart();
      });
      nextButton.addEventListener('click', async () => {
        if (nextButton.disabled) return;
        nextButton.disabled = true;
        summaryDialog.close();
        if (activeMode === 'custom') {
          restart(activeCustomText);
          nextButton.disabled = false;
          return;
        }
        await startBuiltIn();
        nextButton.disabled = false;
      });

      const setKeyboardOpen = (open) => {
        app.classList.toggle('keyboard-collapsed', !open);
        $('keyboard-toggle').setAttribute('aria-expanded', String(open));
        $('keyboard-toggle-label').textContent = open ? '收起软键盘' : '呼出软键盘';
        localStorage.setItem(STORAGE.keyboardOpen, String(open));
      };
      setKeyboardOpen(localStorage.getItem(STORAGE.keyboardOpen) !== 'false');
      $('keyboard-toggle').addEventListener('click', () => {
        setKeyboardOpen($('keyboard-toggle').getAttribute('aria-expanded') !== 'true');
      });

      const syncRandomAvailability = () => {
        const hasCustomText = Boolean(customText.value.trim());
        randomizeInput.disabled = !hasCustomText;
        $('random-help').textContent = hasCustomText
          ? '仅用于自定义文本，每次开始都会重新打乱。'
          : '内置一言本身随机，无需开启。';
      };
      const updateSettings = () => {
        customText.value = activeCustomText;
        randomizeInput.checked = randomizeCustom;
        $('char-count').textContent = String(customText.value.length);
        $('settings-error').textContent = '';
        const best = getBest();
        $('best-cpm').textContent = best ? String(best.cpm) : '—';
        syncRandomAvailability();
      };

      $('open-settings').addEventListener('click', () => {
        updateSettings();
        settingsDialog.showModal();
      });
      customText.addEventListener('input', () => {
        $('char-count').textContent = String(customText.value.length);
        $('settings-error').textContent = '';
        syncRandomAvailability();
      });
      randomizeInput.addEventListener('change', () => {
        randomizeCustom = randomizeInput.checked;
        localStorage.setItem(STORAGE.randomize, String(randomizeCustom));
      });
      $('start-custom').addEventListener('click', () => {
        const value = customText.value.trim();
        try {
          randomizeCustom = randomizeInput.checked;
          createSession(value, { randomize: randomizeCustom });
          activeCustomText = value;
          activeText = value;
          activeMode = 'custom';
          activeQuote = null;
          localStorage.setItem(STORAGE.customText, value);
          localStorage.setItem(STORAGE.randomize, String(randomizeCustom));
          settingsDialog.close();
          restart(value);
        } catch (error) {
          $('settings-error').textContent = error.message;
        }
      });
      $('restore-default').addEventListener('click', async () => {
        activeCustomText = '';
        localStorage.removeItem(STORAGE.customText);
        customText.value = '';
        settingsDialog.close();
        await startBuiltIn();
        showToast('已恢复一言随机文本');
      });
      $('clear-score').addEventListener('click', () => {
        localStorage.removeItem(STORAGE.best);
        $('best-cpm').textContent = '—';
        showToast('已清除本机成绩');
      });

      document.querySelector('.back').addEventListener('click', (event) => {
        if (history.length > 1 && document.referrer.startsWith(location.origin)) {
          event.preventDefault();
          history.back();
        }
      });

      const installButton = $('install');
      const isStandalone = matchMedia('(display-mode: standalone)').matches || navigator.standalone;
      const isSamsung = /SamsungBrowser/i.test(navigator.userAgent);
      const isIOS = /iPad|iPhone|iPod/i.test(navigator.userAgent);
      let installPrompt;
      const markInstalled = () => {
        installButton.textContent = '已安装';
        installButton.disabled = true;
        installPrompt = undefined;
      };
      if (isStandalone) markInstalled();
      addEventListener('beforeinstallprompt', (event) => {
        event.preventDefault();
        installPrompt = event;
      });
      addEventListener('appinstalled', () => {
        markInstalled();
        showToast('已经安装到设备');
      });
      installButton.addEventListener('click', async () => {
        if (isSamsung) {
          showToast('三星浏览器安装包可能触发安全警告，建议改用最新版 Chrome 安装');
          return;
        }
        if (installPrompt) {
          await installPrompt.prompt();
          const { outcome } = await installPrompt.userChoice;
          showToast(outcome === 'accepted' ? '正在安装…' : '已取消安装，可以稍后重试');
          installPrompt = undefined;
          return;
        }
        showToast(
          isIOS
            ? '请点 Safari 分享按钮，再选择「添加到主屏幕」'
            : '请打开浏览器菜单，选择「安装应用」或「添加到主屏幕」'
        );
      });

      if ('serviceWorker' in navigator) {
        addEventListener('load', () => {
          navigator.serviceWorker.register('/tools/flypy/sw.js', { updateViaCache: 'none' });
        });
      }
      setInterval(() => {
        if (session?.status === 'running') renderStats();
      }, 500);

      if (activeCustomText) restart(activeCustomText);
      else void startBuiltIn();
    </script>
